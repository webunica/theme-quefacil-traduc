{% render 'grid-styles' %}
{% render 'section-boundaries', section_id: section.id, section_settings: section.settings %}
<style>
     .section#shopify-section-{{ section.id }} .team-member.grid--2-col-tablet-down .freshcart-grid__item img {
        width:100%;
    }

   .section#shopify-section-{{ section.id }} .freshcart-grid__item img {
      max-width:100%;
      display: flex;
      margin: 0 auto;
    }

    @media (min-width: 990px) and (max-width: 1199px) {
      .section.team-member#shopify-section-{{ section.id }} .grid--5-col-desktop .freshcart-grid__item {
          width: calc(33.33% - var(--spacing_grid_horizontal)* 4 / 5);
          max-width: calc(33.33% - var(--spacing_grid_horizontal)* 4 / 5);
      }
  }
  @media (min-width: 1200px) {
      .section.team-member#shopify-section-{{ section.id }} .team-member-layout {
         margin: 0 -15px;
      }
  }
</style>
<div class="team-member section-{{ section.id }}">
  <div class="team-member-layout {{ section.settings.layout_style }}">
    <{{ section.settings.heading_size_text }}
      class="container"
      style="color: {{ section.settings.heading_color }}; text-align: {{ section.settings.heading_align }};margin-bottom:50px;"
    >
      {{- section.settings.title -}}
    </{{ section.settings.heading_size_text }}>
    <div
      class="team-member grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
      style="gap: {{ section.settings.space_between }}px;"
    >
      {%- for block in section.blocks -%}
        <div
          class="freshcart-grid__item team-members"
          style="background-color: {{ section.settings.bg_color }}; text-align: {{ section.settings.text_align }}; border-radius: {{ section.settings.border_radius }}px;"
        >
          <div
            class="team-member-block"
            style="margin: {{ section.settings.content_margin }}; padding: {{ section.settings.content_padding }};"
          >
            {% if block.settings.name != blank %}
              <h5
                class="team-member-name"
                style="color: {{ block.settings.name_color }}; font-size: {{ block.settings.name_size_text }}; font-weight: {{ block.settings.name_font_weight_body }}; line-height: 1.2;margin:0;"
              >
                {{ block.settings.name }}
              </h5>
            {% endif %}

            {% if block.settings.position != blank %}
              <p
                class="team-member-position"
                style="color: {{ block.settings.pos_color }}; font-size: {{ block.settings.pos_size_text }}; font-weight: {{ block.settings.pos_font_weight_body }}; line-height: 1.5;margin-top: 5px;"
              >
                {{ block.settings.position }}
              </p>
            {% endif %}
          </div>

          <div class="team-member-image-container" style="text-align: center;">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 278 }}"
                alt="{{ block.settings.name | escape }}"
                class="team-member-image"
                width="{{ block.settings.image_width }}"
                height="{{ block.settings.image_height }}"
                loading="lazy"
                style="object-fit: cover;"
              >
            {% else %}
              {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
              <span style="width: 100%; height: 100%; display: inline-block;">
                {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
              </span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

