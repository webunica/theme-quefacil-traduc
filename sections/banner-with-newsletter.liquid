{% render 'section-boundaries', section_id: section.id, section_settings: section.settings %}

<style>
  .section#shopify-section-{{ section.id }} .banner-with-newsletter {
    padding: {{ section.settings.container_padding }};
  }

  .section#shopify-section-{{ section.id }} .banner-with-newsletter__content {
    width: 100%;
  }

  .section#shopify-section-{{ section.id }} .banner-with-newsletter_inner--single {
    display: block !important;
    width: 100%;
  }

  .section#shopify-section-{{ section.id }} .banner-with-newsletter_inner--single .content_block {
    width: 100%;
    max-width: {{ section.settings.content_max_width }}px;
  }

  .section#shopify-section-{{ section.id }} .banner-with-newsletter__button-wrapper {
    width: 100%;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: {{ section.settings.button_wrapper_margin_top }}px;
  }

  .section#shopify-section-{{ section.id }} .section-block__newsletter {
    width: 100%;
    margin-top: {{ section.settings.newsletter_margin_top }}px;
  }

  .section#shopify-section-{{ section.id }} .banner-newsletter-form .field {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .section#shopify-section-{{ section.id }} .banner-newsletter-form .field-container {
    max-width: {{ section.settings.newsletter_input_width }}px;
    width: 100%;
  }

  .section#shopify-section-{{ section.id }} .banner-newsletter-form .field__input {
    width: 100%;
  }

  .section#shopify-section-{{ section.id }} .newsletter-form__button,
  .section#shopify-section-{{ section.id }} .banner-newsletter-form button[type="submit"] {
    background-color: {{ section.settings.newsletter_button_bg }} !important;
    border: 1px solid {{ section.settings.newsletter_button_border }} !important;
    color: {{ section.settings.newsletter_button_color }} !important;
    border-radius: {{ section.settings.newsletter_button_radius }}px;
    padding: {{ section.settings.newsletter_button_padding }};
    font-size: {{ section.settings.newsletter_button_font_size }}px;
    font-weight: {{ section.settings.newsletter_button_font_weight }};
    line-height: 1.2;
    cursor: pointer;
    transition: all .25s ease;
  }

  .section#shopify-section-{{ section.id }} .newsletter-form__button:hover,
  .section#shopify-section-{{ section.id }} .banner-newsletter-form button[type="submit"]:hover {
    background-color: {{ section.settings.newsletter_button_bg_hover }} !important;
    border-color: {{ section.settings.newsletter_button_border_hover }} !important;
    color: {{ section.settings.newsletter_button_color_hover }} !important;
  }

  @media (max-width: 767px) {
    .section#shopify-section-{{ section.id }} .banner-with-newsletter {
      padding: {{ section.settings.container_mobile_padding }} !important;
      min-height: {{ section.settings.height_section_mobile }}px !important;
    }

    .section#shopify-section-{{ section.id }} .banner-with-newsletter_inner--single .content_block {
      max-width: 100%;
    }

    .section#shopify-section-{{ section.id }} .banner-newsletter-form .field {
      align-items: stretch;
    }

    .section#shopify-section-{{ section.id }} .banner-newsletter-form .field-container,
    .section#shopify-section-{{ section.id }} .banner-newsletter-form .submit-container,
    .section#shopify-section-{{ section.id }} .newsletter-form__button {
      width: 100%;
    }
  }
</style>

<div
  class="banner-with-newsletter {{ section.settings.layout_style }} {% if section.settings.layout_style == 'container-fluid' %}stretch-full-width{% endif %} position-relative"
  style="
    {% if section.settings.background_type == 'image' %}
      {% if section.settings.banner_bg_image %}
        background-image: url('{{ section.settings.banner_bg_image | image_url }}');
        background-size: {{ section.settings.background_size }};
        background-repeat: no-repeat;
        background-position: center;
      {% else %}
        background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23e0e0e0%22/></svg>');
        background-size: cover;
        background-position: center;
      {% endif %}
    {% elsif section.settings.background_type == 'color' %}
      background-color: {{ section.settings.bgcolor }};
    {% endif %}
    text-align: {{ section.settings.align }};
    min-height: {{ section.settings.height_section }}px;
    border-radius: {{ section.settings.border_radius }}px;
    display: flex;
    align-items: center;
  "
>
  <div class="banner-with-newsletter__content {% if section.settings.layout_style == 'container-fluid' %}container{% endif %}">
    <div
      class="banner-with-newsletter_inner banner-with-newsletter_inner--single"
      style="align-items: {{ section.settings.content_align }};"
    >
      <div class="content_block">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'sub_title' -%}
              {% if block.settings.pre_text != blank %}
                <p
                  class="banner-with-newsletter__sale"
                  {{ block.shopify_attributes }}
                  style="
                    margin: {{ block.settings.pre_text_margin }};
                    padding: {{ block.settings.txt_padding }};
                    border-radius: {{ block.settings.border_radius }};
                    background-color: {{ block.settings.pre_bg_color }};
                    color: {{ block.settings.pre_color }};
                    text-transform: {{ block.settings.pre_txt_style }};
                    font-size: {{ block.settings.size_text }};
                    font-weight: {{ block.settings.font_weight_body }};
                    line-height: {{ block.settings.lineheight }};
                  "
                >
                  {{ block.settings.pre_text }}
                </p>
              {% endif %}

            {%- when 'heading' -%}
              {% if block.settings.title != blank %}
                <{{ block.settings.h_des_size_text }}
                  class="banner-with-newsletter__heading banner-with-newsletter__heading--{{ block.id }}"
                  {{ block.shopify_attributes }}
                  style="
                    color: {{ block.settings.heading_color }};
                    font-weight: {{ block.settings.h_font_weight }};
                    line-height: {{ block.settings.h_lineheight }};
                    text-transform: {{ block.settings.h_txt_style }};
                    margin: {{ block.settings.heading_margin }};
                  "
                >
                  {{ block.settings.title }}
                </{{ block.settings.h_des_size_text }}>

                <style>
                  @media(max-width: 1023px) {
                    .section#shopify-section-{{ section.id }} .banner-with-newsletter__heading--{{ block.id }} {
                      font-size: {{ block.settings.h_mob_size_text }}px;
                    }
                  }
                </style>
              {% endif %}

            {%- when 'paragraph' -%}
              {% if block.settings.description_text != blank %}
                <p
                  class="banner-with-newsletter__description"
                  {{ block.shopify_attributes }}
                  style="
                    font-size: {{ block.settings.des_size_text }}px;
                    color: {{ block.settings.des_color }};
                    font-weight: {{ block.settings.des_font_weight }};
                    line-height: {{ block.settings.des_lineheight }};
                    margin: {{ block.settings.des_margin }};
                  "
                >
                  {{ block.settings.description_text }}
                </p>
              {% endif %}

          {%- endcase -%}
        {%- endfor -%}

        <div class="banner-with-newsletter__button-wrapper">
          {%- for block in section.blocks -%}
            {% if block.type == 'button' and block.settings.button_text != blank %}
              <div
                class="freshcart-banner-with-newsletter {{ block.settings.btn_style }} button__{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <style>
                  .section#shopify-section-{{ section.id }} .button__{{ block.id }} {
                    width: fit-content;
                  }

                  .section#shopify-section-{{ section.id }} .button__{{ block.id }} a {
                    font-size: {{ block.settings.btn_size_text }};
                    cursor: pointer;
                    color: {{ block.settings.btn_color }};
                    line-height: 1.2;
                    display: block;
                    transition: 0.3s ease-in-out;
                    position: relative;
                    width: fit-content;
                  }

                  {%- if block.settings.btn_style != 'btn-link' -%}
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a {
                      padding: {{ block.settings.btn_padding }};
                      margin: {{ block.settings.btn_margin }};
                      border: {{ block.settings.btn_border }}px solid {{ block.settings.btn_border_color }};
                      border-radius: {{ block.settings.btn_border_radius }};
                      text-decoration: none;
                    }
                  {%- endif -%}

                  {%- if block.settings.btn_style == 'btn-fill' -%}
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a {
                      background-color: {{ block.settings.btn_bg_color }};
                      border: {{ block.settings.btn_border }}px solid {{ block.settings.btn_border_color }};
                    }

                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:hover,
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:focus {
                      background-color: {{ block.settings.btn_bg_hover_color }};
                      color: {{ block.settings.btn_hover_color }};
                      border: {{ block.settings.btn_border }}px solid {{ block.settings.btn_border_hover_color }};
                    }
                  {%- elsif block.settings.btn_style == 'btn-outline' -%}
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a {
                      background-color: transparent;
                    }

                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:hover,
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:focus {
                      border: {{ block.settings.btn_border }}px solid {{ block.settings.btn_border_hover_color }};
                      color: {{ block.settings.btn_hover_color }};
                    }
                  {%- elsif block.settings.btn_style == 'btn-link' -%}
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a {
                      text-decoration: underline;
                      background: transparent;
                    }

                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:hover,
                    .section#shopify-section-{{ section.id }} .button__{{ block.id }} a:focus {
                      color: {{ block.settings.btn_hover_color }};
                    }
                  {%- endif -%}
                </style>

                <a class="button__link" href="{{ block.settings.button_url }}">
                  {{ block.settings.button_text }}
                </a>
              </div>
            {% endif %}
          {%- endfor -%}
        </div>

        {%- if section.settings.newsletter_enable -%}
          <div class="section-block__newsletter">
            {%- if section.settings.newsletter_heading != blank -%}
              <h6 class="section-block__heading inline-richtext">
                {{ section.settings.newsletter_heading }}
              </h6>
            {%- endif -%}

            {%- form 'customer', id: 'NewsletterSection', class: 'section__newsletter banner-newsletter-form' -%}
              <input type="hidden" name="contact[tags]" value="newsletter">

              <div class="newsletter-form__field-wrapper">
                <div class="field">
                  <div class="field-container">
                    <label class="field__label visually-hidden" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>

                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="NewsletterSection-error"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="NewsletterSection-success"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                  </div>

                  <div class="submit-container">
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      id="Subscribe"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      {{ 'newsletter.button_label' | t }}
                    </button>
                  </div>
                </div>

                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="ContactFooter-error">
                    {%- render 'icon-error' -%}
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
              </div>

              {%- if form.posted_successfully? -%}
                <h3
                  class="newsletter-form__message newsletter-form__message--success form__message"
                  id="ContactFooter-success"
                  tabindex="-1"
                  autofocus
                >
                  {% render 'icon-success' -%}
                  {{- 'newsletter.success' | t }}
                </h3>
              {%- endif -%}
            {%- endform -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.banner-with-newsletter.name",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout_style",
      "label": "t:sections.banner-with-newsletter.settings.layout_style.label",
      "default": "container-fluid",
      "options": [
        {
          "value": "container",
          "label": "t:sections.banner-with-newsletter.settings.layout_style.options__1.label"
        },
        {
          "value": "container-fluid",
          "label": "t:sections.banner-with-newsletter.settings.layout_style.options__2.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "t:sections.banner-with-newsletter.settings.background_type.label",
      "options": [
        {
          "value": "image",
          "label": "t:sections.banner-with-newsletter.settings.background_type.options__1.label"
        },
        {
          "value": "color",
          "label": "t:sections.banner-with-newsletter.settings.background_type.options__2.label"
        }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "t:sections.banner-with-newsletter.settings.bgcolor.label",
      "default": "#21313C"
    },
    {
      "type": "image_picker",
      "id": "banner_bg_image",
      "label": "t:sections.banner-with-newsletter.settings.banner_bg_image.label",
      "info": "Imagen de fondo opcional para todo el banner. No agrega imagen lateral derecha."
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "t:sections.banner-with-newsletter.settings.border_radius.label",
      "default": 0
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "t:sections.banner-with-newsletter.settings.background_size.label",
      "default": "cover",
      "options": [
        {
          "label": "t:sections.banner-with-newsletter.settings.background_size.options__1.label",
          "value": "cover"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.background_size.options__2.label",
          "value": "contain"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.background_size.options__3.label",
          "value": "auto"
        }
      ]
    },
    {
      "type": "text",
      "id": "height_section",
      "label": "t:sections.banner-with-newsletter.settings.height_section.label",
      "default": "230"
    },
    {
      "type": "text",
      "id": "height_section_mobile",
      "label": "t:sections.banner-with-newsletter.settings.height_section_mobile.label",
      "default": "300"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Ancho máximo del contenido",
      "default": 760
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "t:sections.banner-with-newsletter.settings.content_align.label",
      "default": "center",
      "options": [
        {
          "label": "t:sections.banner-with-newsletter.settings.content_align.options__1.label",
          "value": "flex-start"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.content_align.options__2.label",
          "value": "center"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.content_align.options__3.label",
          "value": "flex-end"
        }
      ]
    },
    {
      "type": "select",
      "id": "align",
      "label": "t:sections.banner-with-newsletter.settings.align.label",
      "default": "left",
      "options": [
        {
          "label": "t:sections.banner-with-newsletter.settings.align.options__1.label",
          "value": "left"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.align.options__2.label",
          "value": "center"
        },
        {
          "label": "t:sections.banner-with-newsletter.settings.align.options__3.label",
          "value": "right"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.banner-with-newsletter.settings.header.content"
    },
    {
      "type": "text",
      "id": "section_padding_all_sides",
      "label": "t:sections.banner-with-newsletter.settings.section_padding_all_sides.label",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_margin_all_sides",
      "label": "t:sections.banner-with-newsletter.settings.section_margin_all_sides.label",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_padding_mobile_all_sides",
      "label": "t:sections.banner-with-newsletter.settings.paddingmobile.label",
      "default": "0px 0px 0px 0px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_margin_mobile_all_sides",
      "label": "t:sections.banner-with-newsletter.settings.section_margin_mobile_all_sides.label",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "Container Setting"
    },
    {
      "type": "text",
      "id": "container_padding",
      "label": "t:sections.banner-with-newsletter.settings.container_padding.label",
      "default": "50px 64px 64px 64px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "container_mobile_padding",
      "label": "t:sections.banner-with-newsletter.settings.container_mobile_padding.label",
      "default": "30px 15px 15px 15px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "header",
      "content": "Boletín"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.banner-with-newsletter.settings.newsletter_enable.label"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Título opcional sobre formulario"
    },
    {
      "type": "range",
      "id": "newsletter_margin_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Margen superior del formulario",
      "default": 28
    },
    {
      "type": "range",
      "id": "newsletter_input_width",
      "min": 220,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Ancho del campo email",
      "default": 320
    },
    {
      "type": "color",
      "id": "newsletter_button_bg",
      "label": "Fondo botón boletín",
      "default": "#21313C"
    },
    {
      "type": "color",
      "id": "newsletter_button_color",
      "label": "Texto botón boletín",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "newsletter_button_border",
      "label": "Borde botón boletín",
      "default": "#21313C"
    },
    {
      "type": "color",
      "id": "newsletter_button_bg_hover",
      "label": "Fondo hover botón boletín",
      "default": "#0B2F4A"
    },
    {
      "type": "color",
      "id": "newsletter_button_color_hover",
      "label": "Texto hover botón boletín",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "newsletter_button_border_hover",
      "label": "Borde hover botón boletín",
      "default": "#0B2F4A"
    },
    {
      "type": "text",
      "id": "newsletter_button_padding",
      "label": "Padding botón boletín",
      "default": "13px 22px"
    },
    {
      "type": "range",
      "id": "newsletter_button_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Radio botón boletín",
      "default": 6
    },
    {
      "type": "range",
      "id": "newsletter_button_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño texto botón boletín",
      "default": 14
    },
    {
      "type": "select",
      "id": "newsletter_button_font_weight",
      "label": "Peso texto botón boletín",
      "default": "700",
      "options": [
        {
          "value": "400",
          "label": "400"
        },
        {
          "value": "500",
          "label": "500"
        },
        {
          "value": "600",
          "label": "600"
        },
        {
          "value": "700",
          "label": "700"
        }
      ]
    },
    {
      "type": "range",
      "id": "button_wrapper_margin_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Margen superior botones personalizados",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "sub_title",
      "name": "t:sections.banner-with-newsletter.blocks.sub_title.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "pre_text",
          "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.pre_text.label",
          "default": "$30 discount for your first order"
        },
        {
          "type": "color",
          "id": "pre_color",
          "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.pre_color.label",
          "default": "#fff"
        },
        {
          "type": "color",
          "id": "pre_bg_color",
          "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.pre_bg_color.label",
          "default": "transparent"
        },
        {
          "type": "text",
          "id": "size_text",
          "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.size_text.label",
          "default": "14px"
        },
        {
          "type": "text",
          "id": "border_radius",
          "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.border_radius.label",
          "default": "0px"
        },
        {
          "type": "select",
          "id": "pre_txt_style",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.pre_txt_style.options__1.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.banner-with-newsletter.blocks.sub_title.settings.pre_txt_style.options__2.label"
