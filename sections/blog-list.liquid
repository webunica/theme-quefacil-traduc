            "label": "t:sections.blog-list.settings.show_excerpt.label"
        },
        {
            "type": "color",
            "id": "excerpt_color",
            "label": "t:sections.blog-list.settings.excerpt_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "checkbox",
            "id": "show_date",
            "default": true,
            "label": "t:sections.blog-list.settings.show_date.label"
        },
        {
            "type": "color",
            "id": "date_color",
            "label": "t:sections.blog-list.settings.date_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "header",
            "content": "t:sections.blog-list.settings.author.content"
        },
        {
            "type": "checkbox",
            "id": "show_author",
            "default": true,
            "label": "t:sections.blog-list.settings.show_author.label"
        },
        {
            "type": "text",
            "id": "author_text",
            "default": "Author",
            "label": "t:sections.blog-list.settings.author_text.label"
        },
        {
            "type": "color",
            "id": "author_label_color",
            "label": "t:sections.blog-list.settings.author_label_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "color",
            "id": "author_name_color",
            "label": "t:sections.blog-list.settings.author_name_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "header",
            "content": "t:sections.all.padding.section_padding_heading"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 36
        },
        {
