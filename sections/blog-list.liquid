<link
  rel="stylesheet"
  href="{{ 'component-slider.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<link
  rel="stylesheet"
  href="{{ 'component-article-card.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<link
  rel="stylesheet"
  href="{{ 'component-card.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<link
  rel="stylesheet"
  href="{{ 'section-main-blog.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- style -%}
  .section#shopify-section-{{ section.id }}  {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 767px) {
    .section#shopify-section-{{ section.id }}  {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
  }

   .section#shopify-section-{{ section.id }} .blog-list-view .article-card:hover .card__heading a {
    color: {{ section.settings.heading_hover_color | default: 'rgb(var(--color-primary))' }} !important;
  }

  .section#shopify-section-{{ section.id }} .blog-articles.blog-list-view {
    grid-template-columns: 1fr;
  }
{%- endstyle -%}

<div class="page-width">
  <div
    class="section-header-wrapper d-md-flex"
    style="justify-content:space-between; align-items:center; margin: {{ section.settings.heading_margin }}"
  >
    <div class="freshcart-section-header">
      {% if section.settings.title != blank %}
        <{{ section.settings.title_size }}
          class="blog-list-heading"
          style="
            color: {{ section.settings.title_color }};
            font-weight: {{ section.settings.heading_font_weight }};
            line-height: {{ section.settings.heading_lineheight }};
            text-transform: {{ section.settings.heading_txt_style }};
            margin: 0;
          "
        >
          {{ section.settings.title }}
        </{{ section.settings.title_size }}>
        <style>
            @media screen and (max-width: 750px) {

            .section#shopify-section-{{ section.id }} .blog-list-heading {
                font-size: {{ section.settings.heading_mob_size_text }}px !important;
            }
          }
        </style>
      {% endif %}
    </div>
    {% if section.settings.show_view_all %}
      <a
        href="{{ section.settings.view_all_url }}"
        class="view-all"
        style="color: {{ section.settings.view_all_color | default: 'rgb(var(--color-primary))' }}; font-weight: 500; text-decoration: none;"
      >
        {{ section.settings.view_all_text }}
      </a>
    {% endif %}
  </div>
  {%- unless section.settings.heading == blank -%}
    <div class="title-wrapper-with-link">
      <h2
        id="SectionHeading-{{ section.id }}"
        class="blog__title inline-richtext {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
        {% endif %}
      >
        {{ section.settings.blog_heading }}
      </h2>
    </div>
  {%- endunless -%}

  <div
    id="blog-list-view-{{ section.id }}"
    class="blog-articles blog-list-view articles-wrapper contains-card contains-card--article"
    role="list"
  >
    {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
      {%- for article in section.settings.blog.articles limit: section.settings.post_limit -%}
        <div
          id="blog-list-view-item-{{ section.id }}-{{ forloop.index }}"
          class="blog__post {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          {% render 'blog-grid-item',
            blog: section.settings.blog,
            article: article,
            media_aspect_ratio: 1.66,
            show_image: section.settings.show_image,
            show_tag: section.settings.show_tag,
            tag_color: section.settings.tag_color,
            show_date: section.settings.show_date,
            date_color: section.settings.date_color,
            show_author: section.settings.show_author,
            author_text: section.settings.author_text,
            author_label_color: section.settings.author_label_color,
            author_name_color: section.settings.author_name_color,
            show_excerpt: section.settings.show_excerpt
          %}
        </div>
      {%- endfor -%}
    {%- else -%}
      {% for i in (1..section.settings.post_limit) -%}
        <div
          id="blog-list-view-item-{{ section.id }}-{{ forloop.index }}"
          class="blog__post {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div class="article-card-wrapper5 card-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            <div
              class="
                card article-card card--{{ settings.blog_card_style }}
                {% if settings.blog_card_style == 'card' %} color-{{ settings.blog_card_color_scheme }} gradient{% endif %}
                {% if section.settings.show_image %} card--media{% else %} card--text{% endif %}
              "
              style=" {% if settings.blog_card_style == 'standard' %} --ratio-percent: 100%;{% elsif settings.blog_card_style == 'card' %} --ratio-percent: 0%;{% endif %}"
            >
              <div
                class="card__inner{% if settings.blog_card_style == 'standard' %} color-{{ settings.blog_card_color_scheme }} gradient{% endif %} ratio"
                style="--ratio-percent: 80%;"
              >
                {%- if section.settings.show_image == true -%}
                  <div class="article-card__image-wrapper card__media">
                    <div class="article-card__image media">
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg’' }}
                    </div>
                  </div>
                {%- endif -%}
                <div class="card__content">
                  <div class="card__information">
                    <h3 class="card__heading h2 no-link">
                      {{ 'sections.featured_blog.onboarding_title' | t }}
                    </h3>
                    <p class="article-card__excerpt rte-width">
                      {{ 'sections.featured_blog.onboarding_content' | t }}
                    </p>
                  </div>
                </div>
              </div>
              <div class="card__content">
                <div class="card__information">
                  <h3 class="card__heading h2 no-link">
                    {{ 'sections.featured_blog.onboarding_title' | t }}
                  </h3>
                  <p class="article-card__excerpt rte-width">
                    {{ 'sections.featured_blog.onboarding_content' | t }}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
