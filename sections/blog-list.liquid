        {
            "type": "checkbox",
            "id": "show_tag",
            "default": true,
            "label": "t:sections.blog-list.settings.show_tag.label"
        },
        {
            "type": "color",
            "id": "tag_color",
            "label": "t:sections.blog-list.settings.tag_color.label"
        },
        {
            "type": "header",
            "content": "t:sections.blog-list.settings.heading.content"
        },
        {
            "type": "color",
            "id": "heading_color",
            "label": "t:sections.blog-list.settings.heading_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "color",
            "id": "heading_hover_color",
            "label": "t:sections.blog-list.settings.heading_hover_color.label"
        },
        {
            "type": "select",
            "id": "heading_size",
            "label": "t:sections.blog-list.settings.heading_size.label",
            "default": "h2",
            "options": [
                {
                    "value": "h0",
                    "label": "t:sections.blog-list.settings.heading_size.options__1.label"
                },
                {
                    "value": "h1",
                    "label": "t:sections.blog-list.settings.heading_size.options__2.label"
                },
                {
                    "value": "h2",
                    "label": "t:sections.blog-list.settings.heading_size.options__3.label"
                },
                {
                    "value": "h3",
                    "label": "t:sections.blog-list.settings.heading_size.options__4.label"
                },
                {
                    "value": "h4",
                    "label": "t:sections.blog-list.settings.heading_size.options__5.label"
                },
                {
                    "value": "h5",
                    "label": "t:sections.blog-list.settings.heading_size.options__6.label"
                },
                {
                    "value": "h6",
