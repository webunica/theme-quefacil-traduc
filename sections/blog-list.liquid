    "tag": "section",
    "class": "section",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
    "settings": [
        {
            "type": "inline_richtext",
            "id": "title",
            "default": "Our most popular recipes",
            "label": "t:sections.blog-list.settings.title.label"
        },
        {
            "type": "select",
            "id": "title_size",
            "label": "t:sections.blog-list.settings.title_size.label",
            "default": "h3",
            "options": [
                {
                    "value": "h1",
                    "label": "t:sections.blog-list.settings.title_size.options__1.label"
                },
                {
                    "value": "h2",
                    "label": "t:sections.blog-list.settings.title_size.options__2.label"
                },
                {
                    "value": "h3",
                    "label": "t:sections.blog-list.settings.title_size.options__3.label"
                },
                {
                    "value": "h4",
                    "label": "t:sections.blog-list.settings.title_size.options__4.label"
                },
                {
                    "value": "h5",
                    "label": "t:sections.blog-list.settings.title_size.options__5.label"
                },
                {
                    "value": "h6",
                    "label": "t:sections.blog-list.settings.title_size.options__6.label"
                }
            ]
        },
        {
            "type": "color",
            "id": "title_color",
            "label": "t:sections.blog-list.settings.title_color.label",
            "default": "#001e2b"
        },
        {
            "type": "select",
            "id": "heading_txt_style",
            "default": "none",
            "options": [
                {
                    "value": "none",
                    "label": "t:sections.blog-list.settings.heading_txt_style.options__1.label"
                },
                {
                    "value": "uppercase",
                    "label": "t:sections.blog-list.settings.heading_txt_style.options__2.label"
                },
                {
                    "value": "lowercase",
                    "label": "t:sections.blog-list.settings.heading_txt_style.options__3.label"
                }
            ],
            "label": "t:sections.blog-list.settings.heading_txt_style.label"
        },
        {
            "type": "select",
            "id": "heading_font_weight",
            "label": "t:sections.blog-list.settings.heading_font_weight.label",
            "default": "600",
            "options": [
                {
                    "value": "300",
                    "label": "t:sections.blog-list.settings.heading_font_weight.options__1.label"
                },
                {
                    "value": "400",
                    "label": "t:sections.blog-list.settings.heading_font_weight.options__2.label"
                },
                {
                    "value": "500",
                    "label": "t:sections.blog-list.settings.heading_font_weight.options__3.label"
                },
                {
                    "value": "600",
                    "label": "t:sections.blog-list.settings.heading_font_weight.options__4.label"
                },
                {
                    "value": "700",
                    "label": "t:sections.blog-list.settings.heading_font_weight.options__5.label"
                }
            ]
        },
        {
            "type": "text",
            "id": "heading_lineheight",
            "label": "t:sections.blog-list.settings.heading_lineheight.label",
            "default": "1.2"
        },
        {
            "type": "text",
            "id": "heading_mob_size_text",
            "default": "19",
            "label": "t:sections.blog-list.settings.heading_mob_size_text.label"
        },
        {
            "type": "text",
            "id": "heading_margin",
            "label": "t:sections.blog-list.settings.heading_margin.label",
            "default": "0px 0px 24px 0px",
            "info": "Margin: Top Right Bottom Left"
        },
        {
            "type": "checkbox",
            "id": "show_view_all",
            "default": true,
            "label": "t:sections.blog-list.settings.show_view_all.label"
        },
        {
            "type": "text",
            "id": "view_all_text",
            "label": "t:sections.blog-list.settings.view_all_text.label",
            "default": "View all recipes"
        },
        {
            "type": "url",
            "id": "view_all_url",
            "label": "t:sections.blog-list.settings.view_all_url.label"
        },
        {
            "type": "color",
            "id": "view_all_color",
            "label": "t:sections.blog-list.settings.view_all_color.label"
        },
        {
            "type": "header",
            "content": "Blog Setting"
        },
        {
            "type": "blog",
            "id": "blog",
            "label": "t:sections.blog-list.settings.blog.label"
        },
