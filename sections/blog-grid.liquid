{%- style -%}
  .section#shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    margin-top: {{ section.settings.section_margin_top }}px;
    margin-bottom: {{ section.settings.section_margin_bottom }}px;
  }
  .section#shopify-section-{{ section.id }} .blog-articles {
    display: grid;
   row-gap: 32px !important;
    column-gap: 24px !important;
  }
   .section#shopify-section-{{ section.id }} .blog-articles {
    grid-template-columns: 1fr;
  }

  .section#shopify-section-{{ section.id }} .blog-articles .article-card:hover .card__heading a {
    color: {{ section.settings.heading_hover_color | default: 'rgb(var(--color-primary))' }} !important;
  }

  @media(min-width: 1024px ) {
    .section#shopify-section-{{ section.id }} .blog-articles--columns-1 {
      grid-template-columns: 1fr;
    }

    .section#shopify-section-{{ section.id }} .blog-articles--columns-2 {
      grid-template-columns: 1fr 1fr;
    }

    .section#shopify-section-{{ section.id }} .blog-articles--columns-3 {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .section#shopify-section-{{ section.id }} .blog-articles--columns-4 {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }
{%- endstyle -%}

<div class="main-blog page-width section-{{ section.id }}-padding">
  <div
    class="section-header-wrapper d-md-flex"
    style="justify-content:space-between; align-items:center; margin: {{ section.settings.heading_margin }}"
  >
    <div class="freshcart-section-header">
      {% if section.settings.title != blank %}
        <{{ section.settings.title_size }}
          class="blog-heading"
          style="
            color: {{ section.settings.title_color }};
            font-weight: {{ section.settings.heading_font_weight }};
            line-height: {{ section.settings.heading_lineheight }};
            text-transform: {{ section.settings.heading_txt_style }};
            margin: 0;
          "
        >
          {{ section.settings.title }}
        </{{ section.settings.title_size }}>
        <style>
            @media screen and (max-width: 750px) {

            .section#shopify-section-{{ section.id }} .blog-heading {
                font-size: {{ section.settings.heading_mob_size_text }}px !important;
            }
          }
        </style>
      {% endif %}
    </div>
    {% if section.settings.show_view_all %}
      <a
        href="{{ section.settings.view_all_url }}"
        class="view-all"
        style="color: {{ section.settings.view_all_color | default: 'rgb(var(--color-primary))' }}; font-weight: 500; text-decoration: none;"
      >
        {{ section.settings.view_all_text }}
      </a>
    {% endif %}
  </div>

  <ul class="list-unstyled blog-articles blog-articles--columns-{{ section.settings.columns }}">
    {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
      {%- for article in section.settings.blog.articles limit: section.settings.Post_per_page -%}
        <li
          id="post-grid-{{ section.id }}-{{ forloop.index }}"
          class="blog-grid-view blog-articles__article article{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          {% render 'blog-grid-item',
            blog: section.settings.blog,
            article: article,
            media_height: section.settings.image_height,
            media_aspect_ratio: article.image.aspect_ratio,
            show_image: section.settings.show_image,
            show_tag: section.settings.show_tag,
            tag_color: section.settings.tag_color,
            show_date: section.settings.show_date,
            date_color: section.settings.date_color,
            show_author: section.settings.show_author,
            author_label_color: section.settings.author_label_color,
            author_name_color: section.settings.author_name_color,
            author_text: section.settings.author_text,
            show_excerpt: section.settings.show_excerpt
          %}
        </li>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..section.settings.Post_per_page) -%}
        {%- assign placeholder_image_index = forloop.index0 | modulo: 3 | plus: 1 -%}
        {%- assign placeholder_image = 'blog-apparel-' | append: placeholder_image_index -%}
        <li
          id="post-grid-placeholder-{{ section.id }}-{{ forloop.index }}"
          class="blog-grid-view blog-articles__article article placeholder-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          <div
            id="blog-grid-view-item-{{ section.id }}-{{ forloop.index }}"
            class="blog__post {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            <div class="article-card-wrapper card-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              <div
                class="
                  card article-card card--card
                  {% if section.settings.show_image %} card--media{% else %} card--text{% endif %}
                "
                style=" --ratio-percent: 100%;"
              >
                <div
                  class="card__inner{% if settings.blog_card_style == 'standard' %} color-{{ settings.blog_card_color_scheme }} gradient{% endif %} ratio"
                  style="--ratio-percent: 80%;"
                >
                  {%- if section.settings.show_image == true -%}
                    <div class="article-card__image-wrapper card__media">
                      <div class="article-card__image media">
                        {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    </div>
                  {%- endif -%}
                </div>
                <div class="card__content">
                  <div class="card__information">
                    <h3 class="card__heading h5 no-link">
                      {{ 'sections.featured_blog.onboarding_title' | t }}
                    </h3>
                    <p class="article-card__excerpt rte-width">
                      {{ 'sections.featured_blog.onboarding_content' | t }}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </li>
      {%- endfor -%}
    {%- endif -%}
  </ul>
</div>

