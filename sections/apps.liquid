<div class="{% if section.settings.include_margins %}page-width{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  {%- for block in section.blocks -%}
    {% render block %}
  {%- endfor -%}
</div>

<!-- product-rating.liquid -->
<div class="product-rating">
  {% if product.metafields.judgeme.avg_rating > 0 %}
    <div class="average-rating">
      <span class="rating">{{ product.metafields.judgeme.avg_rating }}</span>
      <div class="stars">
        {% for i in (1..5) %}
          {% if i <= product.metafields.judgeme.avg_rating %}
            <span class="star-filled">★</span>
          {% else %}
            <span class="star-empty">☆</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="review-count">({{ product.metafields.judgeme.review_count }} reviews)</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.apps.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "include_margins",
      "default": true,
      "label": "t:sections.apps.settings.include_margins.label"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.apps.presets.name"
    }
  ]
}
{% endschema %}
