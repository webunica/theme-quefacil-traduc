{% render 'section-boundaries', section_id: section.id, section_settings: section.settings %}

<style>
  @media (max-width: 767px) {
    .section#shopify-section-{{ section.id }} {
      min-height: {{ section.settings.height_section_mobile }}px !important;
    }
  }
</style>
<div
  class="call-to-action {{ section.settings.layout_style }} position-relative"
  style="
    {% if section.settings.background_type == 'image' %}
      {% if section.settings.banner_bg_image %}
        background-image: url('{{ section.settings.banner_bg_image | image_url }}');
        background-size: {{ section.settings.background_size }};
        background-repeat: no-repeat;
      {% else %}
        background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23e0e0e0%22/></svg>');
        background-size: cover;
        background-position: center;
      {% endif %}
    {% elsif section.settings.background_type == 'color' %}
      background-color: {{ section.settings.bgcolor }};
    {% endif %}
    text-align: {{ section.settings.align }};
    padding: {{ section.settings.container_padding }};
    border-radius: {{ section.settings.border_radius }}px;
    display: flex;
    align-items: {{ section.settings.align }};
  "
>
  <div class="call-to-action__content" style="width: 100%; ">
    <div class="call-to-action_inner grid grid--2-col-desktop grid--1-col-tablet-down">
      <div class="grid content_block" style="flex: 1; margin-bottom: 0;">
        <div class="image_block">
          <a class="call-to-action_img_link" href="{{ section.settings.image_url }}" style="display: flex;">
            {% if section.settings.banner_image != blank %}
              <img
                src="{{ section.settings.banner_image | image_url: width: section.settings.image_width, height: section.settings.image_height }}"
                alt="image"
                class="about-hero-image"
                width="{{ section.settings.image_width }}"
                height="{{ section.settings.image_height }}"
                loading="lazy"
              >
            {% else %}
              <span style="display: inline-block; width: {{ section.settings.image_width }}px; height: {{ section.settings.image_height }}px;">
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </span>
            {% endif %}
          </a>
        </div>

        {%- liquid
          assign heading_color = section.settings.heading_color
          assign h_font_weight = section.settings.h_font_weight
          assign h_line_height = section.settings.h_lineheight
          assign h_des_font_size = section.settings.h_des_size_text
          assign h_mob_font_size = section.settings.h_mob_size_text
          assign text_transform = section.settings.h_txt_style
          assign heading_margin = section.settings.heading_margin

          assign des_color = section.settings.des_color
          assign des_font_weight = section.settings.des_font_weight
          assign des_line_height = section.settings.des_lineheight
          assign des_font_size = section.settings.des_size_text
          assign desc_margin = section.settings.desc_margin

          assign btn_size_text = section.settings.btn_size_text
          assign btn_color = section.settings.btn_color
          assign btn_hover_color = section.settings.btn_hover_color
          assign btn_bg_color = section.settings.btn_bg_color
          assign btn_bg_hover_color = section.settings.btn_bg_hover_color
          assign btn_color = section.settings.btn_color
          assign btn_border = section.settings.btn_border
          assign btn_border_color = section.settings.btn_border_color
          assign btn_border_hover_color = section.settings.btn_border_hover_color
        -%}

        <div class="text-block" style="align-self: {{ section.settings.content_align }};">
          {% if section.settings.title %}
            <{{ h_des_font_size }}
              class="call-to-action__heading"
              style="color: {{ heading_color }}; font-weight: {{ h_font_weight }}; line-height: {{ h_line_height }}; text-transform: {{ text_transform }}; margin: {{ heading_margin }};"
            >
              {{ section.settings.title }}
              <style>
                @media(max-width: 1023px) {
                  .section#shopify-section-{{ section.id }} .call-to-action__heading {
                    font-size: {{ h_mob_font_size }}px;
                  }
                }
              </style>
            </{{ h_des_font_size }}>
          {% endif %}

          {% if section.settings.description_text %}
            <p
              class="call-to-action__description"
              style="font-size: {{ des_font_size }}; color: {{ des_color }}; font-weight: {{ des_font_weight }}; line-height: {{ des_line_height }}; margin:{{ desc_margin }}"
            >
              {{ section.settings.description_text }}
            </p>
          {% endif %}
        </div>
      </div>
      <div class="button_block" style="align-self: {{ section.settings.content_align }};">
        {% if section.settings.button_text != blank %}
          <div class="freshcart-call-to-action {{ section.settings.btn_style }} button">
            <style>
              .button.freshcart-call-to-action {
                width: fit-content;
              }

              .button.freshcart-call-to-action a {
                font-size: {{ btn_size_text }};
                cursor: pointer;
                color: {{ btn_color }};
                line-height: 1.2;
                display: block;
                transition: 0.3s ease-in-out;
                position: static;
                width: fit-content;
              }

              .button.freshcart-call-to-action a:before {
                position: absolute;
                top: 0;
                right:0;
                bottom: 0;
                left: 0;
                z-index: 1;
                content: "";
                display: block;
                z-index: 2;
              }

              {%- if section.settings.btn_style != 'btn-link' -%}
                .button.freshcart-call-to-action a {
                  padding: {{ section.settings.btn_padding }};
                  margin: {{ section.settings.btn_margin }};
                  border: {{ btn_border }}px solid {{ btn_border_color }};
                  border-radius: {{ section.settings.btn_border_radius }};
                  text-decoration: none;
                }
              {%- endif -%}

              {%- if section.settings.btn_style == 'btn-fill' -%}
                .button.freshcart-call-to-action a {
                  background-color: {{ btn_bg_color }};
                  border: {{ btn_border }}px solid {{ btn_border_color }};
                }

                .button.freshcart-call-to-action a:hover,
                .button.freshcart-call-to-action a:focus {
                  background-color: {{ btn_bg_hover_color }};
                  color: {{ btn_hover_color }};
                  border: {{ btn_border }}px solid {{ btn_border_hover_color }};
                }
              {%- elsif section.settings.btn_style == 'btn-outline' -%}
                .button.freshcart-call-to-action a {
                  background-color: transparent;
                }

                .button.freshcart-call-to-action a:hover,
                .button.freshcart-call-to-action a:focus {
                  border: {{ btn_border }}px solid {{ btn_border_hover_color }};
                  color: {{ btn_hover_color }};
                }
              {%- elsif section.settings.btn_style == 'btn-link' -%}
                .button.freshcart-call-to-action a {
                  text-decoration: underline;
                  background: transparent;
                }

                .button.freshcart-call-to-action a:hover,
                .button.freshcart-call-to-action a:focus {
                  color: {{ btn_hover_color }};
                }
              {%- endif -%}
            </style>
            <a
              class="button__link"
              href="{{ section.settings.button_url }}"
            >
              {{ section.settings.button_text }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
