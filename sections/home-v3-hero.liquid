            "label": "t:sections.home-v3-hero.settings.heading_font_weight.label",
            "default": "700",
            "options": [
                {
                    "value": "300",
                    "label": "t:sections.home-v3-hero.settings.heading_font_weight.options__1.label"
                },
                {
                    "value": "400",
                    "label": "t:sections.home-v3-hero.settings.heading_font_weight.options__2.label"
                },
                {
                    "value": "500",
                    "label": "t:sections.home-v3-hero.settings.heading_font_weight.options__3.label"
                },
                {
                    "value": "600",
                    "label": "t:sections.home-v3-hero.settings.heading_font_weight.options__4.label"
                },
                {
                    "value": "700",
                    "label": "t:sections.home-v3-hero.settings.heading_font_weight.options__5.label"
                }
            ]
        },
        {
            "type": "text",
            "id": "heading_lineheight",
            "label": "t:sections.home-v3-hero.settings.heading_lineheight.label",
            "default": "1.2"
        },
        {
            "type": "text",
            "id": "heading_margin",
            "label": "t:sections.home-v3-hero.settings.heading_margin.label",
            "default": "15px 0px 0px 0px"
        },
        {
            "type": "header",
            "content": "t:sections.home-v3-hero.settings.posttitle_setting.content"
        },
        {
            "type": "text",
            "id": "posttitle",
            "label": "t:sections.home-v3-hero.settings.posttitle.label",
            "default": "Only on this week… Don’t miss"
