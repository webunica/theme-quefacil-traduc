{%- style -%}
  {%- if section.settings.title_font -%}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.pretitle_font -%}
    {{ section.settings.pretitle_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.description_font -%}
    {{ section.settings.description_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  .qf-hero-slider-{{ section.id }} {
    width: 100%;
    margin: {{ section.settings.section_margin }};
    padding: {{ section.settings.section_padding }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__container {
    {% if section.settings.full_width %}
      width: 100%;
      max-width: 100%;
      padding-left: {{ section.settings.side_padding }}px;
      padding-right: {{ section.settings.side_padding }}px;
    {% else %}
      max-width: var(--page-width, 1320px);
      margin-left: auto;
      margin-right: auto;
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    {% endif %}
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__inner {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius }}px;
    background: {{ section.settings.fallback_bg }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__track {
    display: flex;
    width: 100%;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    min-height: {{ section.settings.desktop_height }}px;
    overflow: hidden;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__image,
  .qf-hero-slider-{{ section.id }} .qf-hero-slider__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__image {
    object-fit: cover;
    object-position: {{ section.settings.image_position_desktop }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__image--mobile {
    display: none;
    object-position: {{ section.settings.image_position_mobile }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__placeholder svg {
    width: 100%;
    height: 100%;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity | times: 0.01 }}) 0%,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity | times: 0.006 }}) 45%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__content {
    position: relative;
    z-index: 2;
    min-height: {{ section.settings.desktop_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items:
      {% case section.settings.content_align %}
        {% when 'left' %}flex-start
        {% when 'center' %}center
        {% when 'right' %}flex-end
      {% endcase %};
    text-align:
      {% case section.settings.content_align %}
        {% when 'left' %}left
        {% when 'center' %}center
        {% when 'right' %}right
      {% endcase %};
    max-width: {{ section.settings.content_width }}px;
    padding: {{ section.settings.content_padding_y }}px {{ section.settings.content_padding_x }}px;
    margin:
      {% case section.settings.content_align %}
        {% when 'left' %}0 auto 0 0
        {% when 'center' %}0 auto
        {% when 'right' %}0 0 0 auto
      {% endcase %};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__pretitle {
    margin: 0 0 10px;
    color: {% if section.settings.use_custom_colors %}{{ section.settings.pretitle_color }}{% else %}currentColor{% endif %};
    font-size: {{ section.settings.pretitle_size }}px;
    {%- if section.settings.pretitle_font -%}
    font-family: {{ section.settings.pretitle_font.family }}, {{ section.settings.pretitle_font.fallback_families }};
    font-weight: {{ section.settings.pretitle_font.weight }};
    font-style: {{ section.settings.pretitle_font.style }};
    {%- else -%}
    font-weight: {{ section.settings.pretitle_weight }};
    {%- endif -%}
    line-height: 1.2;
    text-transform: {{ section.settings.pretitle_transform }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__title {
    margin: 0;
    color: {% if section.settings.use_custom_colors %}{{ section.settings.title_color }}{% else %}currentColor{% endif %};
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.05;
    {%- if section.settings.title_font -%}
    font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }};
    font-weight: {{ section.settings.title_font.weight }};
    font-style: {{ section.settings.title_font.style }};
    {%- else -%}
    font-weight: {{ section.settings.title_weight }};
    {%- endif -%}
    letter-spacing: -0.04em;
    text-transform: {{ section.settings.title_transform }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__description {
    margin: 14px 0 0;
    color: {% if section.settings.use_custom_colors %}{{ section.settings.description_color }}{% else %}currentColor{% endif %};
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.5;
    {%- if section.settings.description_font -%}
    font-family: {{ section.settings.description_font.family }}, {{ section.settings.description_font.fallback_families }};
    font-weight: {{ section.settings.description_font.weight }};
    font-style: {{ section.settings.description_font.style }};
    {%- else -%}
    font-weight: {{ section.settings.description_weight }};
    {%- endif -%}
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    margin-top: 20px;
    padding: {{ section.settings.button_padding }};
    border-radius: {{ section.settings.button_radius }}px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_color }};
    border: 1px solid {{ section.settings.button_border }};
    text-decoration: none;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 700;
    line-height: 1.2;
    transition: all 0.25s ease;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__button:hover {
    background: {{ section.settings.button_bg_hover }};
    color: {{ section.settings.button_color_hover }};
    border-color: {{ section.settings.button_border_hover }};
    transform: translateY(-1px);
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow {
    position: absolute;
    top: 50%;
    z-index: 5;
    width: {{ section.settings.arrow_size }}px;
    height: {{ section.settings.arrow_size }}px;
    border-radius: 999px;
    border: 1px solid {{ section.settings.arrow_border }};
    background: {{ section.settings.arrow_bg }};
    color: {{ section.settings.arrow_color }};
    display: {% if section.settings.show_arrows %}inline-flex{% else %}none{% endif %};
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transform: translateY(-50%);
    transition: all 0.25s ease;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow:hover {
    background: {{ section.settings.arrow_bg_hover }};
    color: {{ section.settings.arrow_color_hover }};
    border-color: {{ section.settings.arrow_border_hover }};
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow--prev {
    left: {{ section.settings.arrow_offset }}px;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow--next {
    right: {{ section.settings.arrow_offset }}px;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow svg {
    width: 18px;
    height: 18px;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__dots {
    position: absolute;
    left: 50%;
    bottom: {{ section.settings.dots_bottom }}px;
    z-index: 5;
    display: {% if section.settings.show_dots %}flex{% else %}none{% endif %};
    gap: 8px;
    transform: translateX(-50%);
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, .55);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .qf-hero-slider-{{ section.id }} .qf-hero-slider__dot.is-active {
    width: 26px;
    background: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .qf-hero-slider-{{ section.id }} {
      margin: {{ section.settings.section_margin_mobile }};
      padding: {{ section.settings.section_padding_mobile }};
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__container {
      padding-left: {{ section.settings.side_padding_mobile }}px;
      padding-right: {{ section.settings.side_padding_mobile }}px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__slide {
      min-height: {{ section.settings.mobile_height }}px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__content {
      min-height: {{ section.settings.mobile_height }}px;
      max-width: 100%;
      padding: {{ section.settings.content_padding_y_mobile }}px {{ section.settings.content_padding_x_mobile }}px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__image--desktop.has-mobile {
      display: none;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__image--mobile {
      display: block;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__description {
      font-size: {{ section.settings.description_size_mobile }}px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow {
      width: 36px;
      height: 36px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow--prev {
      left: 10px;
    }

    .qf-hero-slider-{{ section.id }} .qf-hero-slider__arrow--next {
      right: 10px;
    }
  }
{%- endstyle -%}

<section
  class="qf-hero-slider qf-hero-slider-{{ section.id }}{% if section.settings.color_scheme != blank %} color-{{ section.settings.color_scheme }} gradient{% endif %}"
  data-qf-hero-slider="{{ section.id }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed }}"
>
  <div class="qf-hero-slider__container">
    <div class="qf-hero-slider__inner">
      <div class="qf-hero-slider__track" data-slider-track>
        {% for block in section.blocks %}
          <div
            class="qf-hero-slider__slide"
            data-slider-slide
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image_desktop %}
              <img
                src="{{ block.settings.image_desktop | image_url: width: 2200 }}"
                alt="{{ block.settings.image_alt | escape }}"
                width="2200"
                height="{{ section.settings.desktop_height }}"
                class="qf-hero-slider__image qf-hero-slider__image--desktop {% if block.settings.image_mobile %}has-mobile{% endif %}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {% else %}
              <div class="qf-hero-slider__placeholder">
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}

            {% if block.settings.image_mobile %}
              <img
                src="{{ block.settings.image_mobile | image_url: width: 900 }}"
                alt="{{ block.settings.image_alt | escape }}"
                width="900"
                height="{{ section.settings.mobile_height }}"
                class="qf-hero-slider__image qf-hero-slider__image--mobile"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {% endif %}

            <div class="qf-hero-slider__overlay"></div>

            <div class="qf-hero-slider__content">
              {% if block.settings.pretitle != blank %}
                <p class="qf-hero-slider__pretitle">
                  {{ block.settings.pretitle }}
                </p>
              {% endif %}

              {% if block.settings.title != blank %}
                <h1 class="qf-hero-slider__title">
                  {{ block.settings.title }}
                </h1>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class="qf-hero-slider__description">
                  {{ block.settings.description }}
                </div>
              {% endif %}

              {% if block.settings.button_text != blank %}
                <a
                  href="{{ block.settings.button_url }}"
                  class="qf-hero-slider__button"
                >
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <button class="qf-hero-slider__arrow qf-hero-slider__arrow--prev" type="button" aria-label="Anterior" data-slider-prev>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button class="qf-hero-slider__arrow qf-hero-slider__arrow--next" type="button" aria-label="Siguiente" data-slider-next>
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="qf-hero-slider__dots" data-slider-dots>
          {% for block in section.blocks %}
            <button
              type="button"
              class="qf-hero-slider__dot {% if forloop.first %}is-active{% endif %}"
              aria-label="Ir al slide {{ forloop.index }}"
              data-slider-dot="{{ forloop.index0 }}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('[data-qf-hero-slider="{{ section.id }}"]');
    if (!section) return;

    const track = section.querySelector('[data-slider-track]');
    const slides = Array.from(section.querySelectorAll('[data-slider-slide]'));
    const prev = section.querySelector('[data-slider-prev]');
    const next = section.querySelector('[data-slider-next]');
    const dots = Array.from(section.querySelectorAll('[data-slider-dot]'));

    if (!track || slides.length <= 1) return;

    const autoplayEnabled = section.dataset.autoplay === 'true';
    const autoplaySpeed = Number(section.dataset.autoplaySpeed || 5000);

    let index = 0;
    let autoplayTimer = null;

    function goToSlide(newIndex) {
      if (newIndex < 0) {
        index = slides.length - 1;
      } else if (newIndex >= slides.length) {
        index = 0;
      } else {
        index = newIndex;
      }

      track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle('is-active', dotIndex === index);
      });
    }

    function startAutoplay() {
      if (!autoplayEnabled) return;
      stopAutoplay();
      autoplayTimer = setInterval(() => {
        goToSlide(index + 1);
      }, autoplaySpeed);
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    }

    prev?.addEventListener('click', () => {
      goToSlide(index - 1);
      startAutoplay();
    });

    next?.addEventListener('click', () => {
      goToSlide(index + 1);
      startAutoplay();
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goToSlide(Number(dot.dataset.sliderDot));
        startAutoplay();
      });
    });

    section.addEventListener('mouseenter', stopAutoplay);
    section.addEventListener('mouseleave', startAutoplay);

    startAutoplay();

    document.addEventListener('shopify:section:load', () => {
      goToSlide(0);
      startAutoplay();
    });
  })();
</script>

{% schema %}
{
  "name": "QF Hero Slider",
  "settings": [
    {
      "type": "header",
      "content": "Contenedor"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Usar ancho completo",
      "default": false
    },
    {
      "type": "range",
      "id": "side_padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding lateral desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "side_padding_mobile",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Padding lateral mobile",
      "default": 16
    },
    {
      "type": "text",
      "id": "section_margin",
      "label": "Margen sección desktop",
      "default": "32px 0 0 0"
    },
    {
      "type": "text",
      "id": "section_padding",
      "label": "Padding sección desktop",
      "default": "0 0 0 0"
    },
    {
      "type": "text",
      "id": "section_margin_mobile",
      "label": "Margen sección mobile",
      "default": "20px 0 0 0"
    },
    {
      "type": "text",
      "id": "section_padding_mobile",
      "label": "Padding sección mobile",
      "default": "0 0 0 0"
    },
    {
      "type": "header",
      "content": "Esquema y colores"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de colores del theme"
    },
    {
      "type": "checkbox",
      "id": "use_custom_colors",
      "label": "Usar colores personalizados para textos y botones",
      "default": true
    },
    {
      "type": "color",
      "id": "fallback_bg",
      "label": "Color de fondo si no hay imagen",
      "default": "#0aad0a"
    },
    {
      "type": "color",
      "id": "pretitle_color",
      "label": "Color pretítulo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color título",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color descripción",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Diseño del banner"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 280,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Alto desktop",
      "default": 420
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 280,
      "max": 720,
      "step": 20,
      "unit": "px",
      "label": "Alto mobile",
      "default": 420
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Borde redondeado",
      "default": 8
    },
    {
      "type": "select",
      "id": "image_position_desktop",
      "label": "Posición imagen desktop",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Centro"
        },
        {
          "value": "left center",
          "label": "Izquierda"
        },
        {
          "value": "right center",
          "label": "Derecha"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Posición imagen mobile",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Centro"
        },
        {
          "value": "left center",
          "label": "Izquierda"
        },
        {
          "value": "right center",
          "label": "Derecha"
        }
      ]
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Oscurecer imagen",
      "default": 15
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Alineación contenido",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ]
    },
    {
      "type": "range",
      "id": "content_width",
      "min": 280,
      "max": 780,
      "step": 20,
      "unit": "px",
      "label": "Ancho máximo contenido",
      "default": 520
    },
    {
      "type": "range",
      "id": "content_padding_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical desktop",
      "default": 56
    },
    {
      "type": "range",
      "id": "content_padding_x",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal desktop",
      "default": 56
    },
    {
      "type": "range",
      "id": "content_padding_y_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding vertical mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_padding_x_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding horizontal mobile",
      "default": 24
    },
    {
      "type": "header",
      "content": "Tipografía y Fuentes"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Fuente del título",
      "default": "work_sans_n6"
    },
    {
      "type": "font_picker",
      "id": "pretitle_font",
      "label": "Fuente del pretítulo",
      "default": "work_sans_n4"
    },
    {
      "type": "font_picker",
      "id": "description_font",
      "label": "Fuente de la descripción",
      "default": "work_sans_n4"
    },
    {
      "type": "range",
      "id": "pretitle_size",
      "min": 10,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Tamaño pretítulo",
      "default": 14
    },
    {
      "type": "select",
      "id": "pretitle_weight",
      "label": "Peso pretítulo",
      "default": "700",
      "options": [
        {
          "value": "400",
          "label": "400"
        },
        {
          "value": "500",
          "label": "500"
        },
        {
          "value": "600",
          "label": "600"
        },
        {
          "value": "700",
          "label": "700"
        }
      ]
    },
