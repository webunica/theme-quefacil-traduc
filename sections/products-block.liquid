<link
  rel="stylesheet"
  href="{{ 'products-block.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'component-price.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'template-collection.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
{%- if section.settings.show_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section#shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
  }

  .section-header-wrapper {
    justify-content: space-between;
    align-items: center;
  }
{%- endstyle -%}

{%- liquid
  assign products_to_display = section.settings.collection.products_count | default: 0

  if section.settings.collection.all_products_count > section.settings.products_to_show
    assign products_to_display = section.settings.products_to_show
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign show_mobile_slider = false
  if section.settings.swipe_on_mobile and section.settings.products_to_show > columns_mobile_int
    assign show_mobile_slider = true
  endif
-%}

<div class="{{ section.settings.layout_type }}">
  {% if section.settings.title != blank
    or section.settings.description_text != blank
    or section.settings.show_view_all
  %}
    <div class="section-header-wrapper d-md-flex" style="margin: {{ section.settings.section_header_margin }}">
      {% if section.settings.title != blank or section.settings.description_text != blank %}
        <div class="freshcart-section-header">
          <style>
            .freshcart-section-header h3.product-block-heading,
            .freshcart-section-header p {
                margin: 0 !important;
            }
            .card__heading .card__heading--link {
              color: rgb(var(--color-gray-800 ) );
              text-decoration: none;
            }

            .card-information .vendor-name {
               color: rgb(var(--color-secondary-text ) );
              font-size: 13px;
            }
          </style>
          {% if section.settings.title != blank %}
            <h3
              class="product-block-heading {{ section.settings.heading_size }}"
              style="color:{{ section.settings.title_color }}"
            >
              {{ section.settings.title }}
            </h3>
          {% endif %}

          {% if section.settings.description_text != blank %}
            <p
              class="product-block-description"
              style="font-weight: {{ section.settings.font_weight }}; color: {{ section.settings.description_color }}"
            >
              {{ section.settings.description_text }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.show_view_all %}
        <a
          href="{{ section.settings.collection.url }}"
          class="view-all"
          style="color: {{ section.settings.view_all_color }}; font-weight: 500; text-decoration: none;"
        >
          {{ section.settings.view_all_text }}
        </a>
      {% endif %}
    </div>
  {% endif %}
  <slider-component class="slider-mobile-gutter {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    <ul
      id="Slider-{{ section.id }}"
      class="product-grid grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down {% if section.settings.swipe_on_mobile %} slider slider--tablet grid--peek{% endif %}"
    >
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        <li
          id="Slide-{{ section.id }}-{{ forloop.index }}"
          class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
          {% endif %}
        >
          {% render 'product-item',
            card_product: product,
            media_aspect_ratio: section.settings.image_ratio,
            show_secondary_image: section.settings.show_secondary_image,
            show_vendor: section.settings.show_vendor,
            show_rating: section.settings.show_rating,
            section_id: section.id,
            show_quick_add: section.settings.show_quick_add
          %}
        </li>
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} {% if show_mobile_slider %} slider__slide{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {%- assign placeholder_image_index = forloop.index0 | modulo: 6 | plus: 1 -%}
            {%- assign placeholder_image = 'product-' | append: placeholder_image_index -%}
            {% render 'product-item', show_vendor: section.settings.show_vendor, placeholder_image: placeholder_image %}
          </li>
        {%- endfor -%}
      {%- endfor -%}
    </ul>
    {%- if show_mobile_slider -%}
      <div class="slider-buttons">
        <button
          type="button"
          class="slider-button slider-button--prev"
          name="previous"
          aria-label="{{ 'general.slider.previous_slide' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {% render 'icon-caret' %}
        </button>
        <div class="slider-counter caption">
          <span class="slider-counter--current">1</span>
          <span aria-hidden="true"> / </span>
          <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
          <span class="slider-counter--total">{{ products_to_display }}</span>
        </div>
        <button
          type="button"
          class="slider-button slider-button--next"
          name="next"
          aria-label="{{ 'general.slider.next_slide' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {% render 'icon-caret' %}
        </button>
      </div>
    {%- endif -%}
  </slider-component>
</div>

{% schema %}
{
    "name": "t:sections.products-block.name",
    "tag": "section",
    "class": "section product-section-padding",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
    "settings": [
        {
            "type": "select",
            "id": "layout_type",
            "label": "t:sections.products-block.settings.layout_type.label",
            "options": [
                {
                    "value": "container",
                    "label": "t:sections.products-block.settings.layout_type.options__1.label"
                },
                {
                    "value": "container-fluid",
                    "label": "t:sections.products-block.settings.layout_type.options__2.label"
                }
            ],
            "default": "container"
        },
        {
            "type": "header",
            "content": "t:sections.products-block.settings.section_header.content"
        },
        {
            "type": "inline_richtext",
            "id": "title",
            "default": "Our Products",
            "label": "t:sections.products-block.settings.title.label"
        },
        {
            "type": "select",
            "id": "heading_size",
            "label": "t:sections.products-block.settings.heading_size.label",
            "default": "h3",
            "options": [
                {
                    "value": "h0",
                    "label": "t:sections.products-block.settings.heading_size.options__1.label"
                },
                {
                    "value": "h1",
                    "label": "t:sections.products-block.settings.heading_size.options__2.label"
                },
                {
                    "value": "h2",
                    "label": "t:sections.products-block.settings.heading_size.options__3.label"
                },
                {
                    "value": "h3",
                    "label": "t:sections.products-block.settings.heading_size.options__4.label"
                },
                {
                    "value": "h4",
                    "label": "t:sections.products-block.settings.heading_size.options__5.label"
                },
                {
                    "value": "h5",
                    "label": "t:sections.products-block.settings.heading_size.options__6.label"
                },
                {
                    "value": "h6",
                    "label": "t:sections.products-block.settings.heading_size.options__7.label"
                }
            ]
        },
        {
            "type": "color",
            "id": "title_color",
            "default": "#001e2b",
            "label": "t:sections.products-block.settings.title_color.label"
        },
        {
            "type": "inline_richtext",
            "id": "description_text",
            "label": "t:sections.products-block.settings.description_text.label"
        },
        {
            "type": "select",
            "id": "font_weight",
            "label": "t:sections.products-block.settings.font_weight.label",
            "options": [
                {
                    "value": "400",
                    "label": "400"
                },
                {
                    "value": "500",
                    "label": "500"
                },
                {
                    "value": "600",
                    "label": "600"
                }
            ],
            "default": "500"
        },
        {
            "type": "color",
            "id": "description_color",
            "label": "t:sections.products-block.settings.description_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "checkbox",
            "id": "show_view_all",
            "default": true,
            "label": "t:sections.products-block.settings.show_view_all.label"
        },
        {
            "type": "text",
            "id": "view_all_text",
            "label": "t:sections.products-block.settings.view_all_text.label",
            "default": "View All"
        },
        {
            "type": "color",
            "id": "view_all_color",
            "label": "t:sections.products-block.settings.view_all_color.label"
        },
        {
            "type": "text",
            "id": "section_header_margin",
            "label": "t:sections.products-block.settings.section_header_margin.label",
            "default": "0px 0px 24px 0px",
            "info": "t:sections.products-block.settings.section_header_margin.info"
        },
        {
            "type": "header",
            "content": "t:sections.products-block.settings.product_content.content"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "t:sections.products-block.settings.collection.label"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 2,
            "max": 25,
            "step": 1,
            "default": 4,
            "label": "t:sections.products-block.settings.products_to_show.label"
        },
        {
            "type": "range",
            "id": "columns_desktop",
            "min": 1,
            "max": 6,
            "step": 1,
            "default": 4,
            "label": "t:sections.products-block.settings.columns_desktop.label"
        },
        {
            "type": "header",
            "content": "t:sections.products-block.settings.header_content.content"
        },
        {
            "type": "select",
            "id": "image_ratio",
            "options": [
                {
                    "value": "adapt",
                    "label": "t:sections.products-block.settings.image_ratio.options__1.label"
                },
                {
                    "value": "portrait",
                    "label": "t:sections.products-block.settings.image_ratio.options__2.label"
                },
                {
                    "value": "square",
                    "label": "t:sections.products-block.settings.image_ratio.options__3.label"
                }
            ],
            "default": "adapt",
            "label": "t:sections.products-block.settings.image_ratio.label"
        },
        {
            "type": "checkbox",
            "id": "show_secondary_image",
            "default": false,
            "label": "t:sections.products-block.settings.show_secondary_image.label"
        },
        {
            "type": "checkbox",
            "id": "show_vendor",
            "default": false,
            "label": "t:sections.products-block.settings.show_vendor.label"
        },
        {
            "type": "checkbox",
            "id": "show_rating",
            "default": false,
            "label": "t:sections.products-block.settings.show_rating.label",
            "info": "t:sections.products-block.settings.show_rating.info"
        },
        {
            "type": "checkbox",
            "id": "show_quick_add",
            "default": false,
            "label": "t:sections.products-block.settings.show_quick_add.label",
            "info": "t:sections.products-block.settings.show_quick_add.info"
        },
        {
            "type": "header",
            "content": "t:sections.products-block.settings.header_mobile.content"
        },
        {
            "type": "select",
            "id": "columns_mobile",
            "default": "2",
            "label": "t:sections.products-block.settings.columns_mobile.label",
            "options": [
                {
                    "value": "1",
                    "label": "t:sections.products-block.settings.columns_mobile.options__1.label"
                },
                {
                    "value": "2",
                    "label": "t:sections.products-block.settings.columns_mobile.options__2.label"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "swipe_on_mobile",
            "default": false,
            "label": "t:sections.products-block.settings.swipe_on_mobile.label"
        },
        {
            "type": "header",
            "content": "t:sections.all.padding.section_padding_heading"
        },
        {
            "type": "range",
            "id": "padding_top",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_top",
            "default": 0
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.padding.padding_bottom",
            "default": 0
        },
        {
            "type": "header",
            "content": "t:sections.all.margin.section_margin_heading"
        },
        {
            "type": "range",
            "id": "margin_top",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.margin.margin_top",
            "default": 80
        },
        {
            "type": "range",
            "id": "margin_bottom",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.all.margin.margin_bottom",
            "default": 0
        }
    ],
    "presets": [
        {
            "name": "t:sections.products-block.presets.name"
        }
    ]
}
{% endschema %}
