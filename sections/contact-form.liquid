<link
  rel="stylesheet"
  href="{{ 'section-contact-form.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="contact freshcart-contact-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank or section.settings.description != blank -%}
    <div class="contact-page-header" style="margin-bottom:25px;">
      {%- if section.settings.heading != blank -%}
        <h2
          class="title title-wrapper--no-top-margin inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="margin:0;"
        >
          {{ section.settings.heading }}
        </h2>
      {%- else -%}
        <h2 class="visually-hidden">{{ 'templates.contact.form.title' | t }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p
          class="desc"
          style="color: {{ section.settings.desc_color }};font-size:17.5px;line-height:26px;margin-top:10px;margin-bottom:0;"
        >
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- liquid
    assign contact_form_class = 'isolate'
    if settings.animations_reveal_on_scroll
      assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
    endif
  -%}
  {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
    {%- if form.posted_successfully? -%}
      <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
        {% render 'icon-success' %}
        {{ 'templates.contact.form.post_success' | t }}
      </h2>
    {%- elsif form.errors -%}
      <div class="form__message">
        <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
          {% render 'icon-error' %}
          {{ 'templates.contact.form.error_heading' | t }}
        </h2>
      </div>
      <ul class="form-status-list caption-large" role="list">
        <li>
          <a href="#ContactForm-email" class="link">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </a>
        </li>
      </ul>
    {%- endif -%}
    <div class="contact__fields">
      <div class="field">
        <input
          class="field__input"
          autocomplete="name"
          type="text"
          id="ContactForm-name"
          name="contact[{{ 'templates.contact.form.name' | t }}]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
        >
        <label class="field__label" for="ContactForm-name">
          {{- 'templates.contact.form.name' | t }}
          <span aria-hidden="true">*</span></label
        >
      </div>
      <div class="field">
        <input
          class="field__input"
          type="text"
          id="ContactForm-last-name"
          name="contact[{{ 'templates.contact.form.last_name' | t }}]"
          value="{% if form.last_name %}{{ form.last_name }}{% elsif customer %}{{ customer.last_name }}{% endif %}"
        >
        <label class="field__label" for="ContactForm-last-name">{{ 'templates.contact.form.last_name' | t }}</label>
      </div>
      <div class="field">
        <input
          type="text"
          id="ContactForm-company"
          class="field__input"
          autocomplete="company"
          name="contact[{{ 'templates.contact.form.company' | t }}]"
          value="{% if form.company %}{{ form.company }}{% elsif customer %}{{ customer.company }}{% endif %}"
        >
        <label class="field__label" for="ContactForm-company">{{ 'templates.contact.form.company' | t }}</label>
      </div>
      <div class="field">
        <input
          type="text"
          id="ContactForm-your_title"
          class="field__input"
          autocomplete="title"
          name="contact[{{ 'templates.contact.form.your_title' | t }}]"
          value="{% if form.your_title %}{{ form.your_title }}{% elsif customer %}{{ customer.your_title }}{% endif %}"
        >
        <label class="field__label" for="ContactForm-your_title">{{ 'templates.contact.form.your_title' | t }}</label>
      </div>
    </div>
    <div class="contact__fields1">
      <div class="field field--with-error">
        <input
          autocomplete="email"
          type="email"
          id="ContactForm-email"
          class="field__input"
          name="contact[email]"
          spellcheck="false"
          autocapitalize="off"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          aria-required="true"
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="ContactForm-email-error"
          {% endif %}
          placeholder=""
        >
        <label class="field__label" for="ContactForm-email">
          {{- 'templates.contact.form.email' | t }}
          <span aria-hidden="true">*</span></label
        >
        {%- if form.errors contains 'email' -%}
          <small class="contact__field-error" id="ContactForm-email-error">
            <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
            <span class="form__message">
              {%- render 'icon-error' -%}
              {{- form.errors.translated_fields.email | capitalize }}
              {{ form.errors.messages.email -}}
            </span>
          </small>
        {%- endif -%}
      </div>
      <div class="field">
        <input
          type="tel"
          id="ContactForm-phone"
          class="field__input"
          autocomplete="tel"
          name="contact[{{ 'templates.contact.form.phone' | t }}]"
          pattern="[0-9\-]*"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
        >
        <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
      </div>
      <div class="field">
        <textarea
          rows="10"
          id="ContactForm-body"
          class="text-area field__input"
          name="contact[{{ 'templates.contact.form.comment' | t }}]"
        >
            {{- form.body -}}
          </textarea>
        <label class="form__label field__label" for="ContactForm-body">
          {{- 'templates.contact.form.comment' | t -}}
        </label>
      </div>
    </div>
    <div class="contact__button6">
      <button type="submit" class="button button--primary">
        {{ 'templates.contact.form.send' | t }}
      </button>
    </div>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "contact-form-section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Contact form",
      "label": "t:sections.contact-form.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h0",
          "label": "t:sections.contact-form.settings.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.contact-form.settings.heading_size.options__2.label"
        },
        {
          "value": "h2",
          "label": "t:sections.contact-form.settings.heading_size.options__3.label"
        },
        {
          "value": "h3",
          "label": "t:sections.contact-form.settings.heading_size.options__4.label"
        },
        {
          "value": "h4",
          "label": "t:sections.contact-form.settings.heading_size.options__5.label"
        },
        {
          "value": "h5",
          "label": "t:sections.contact-form.settings.heading_size.options__6.label"
        },
        {
          "value": "h6",
          "label": "t:sections.contact-form.settings.heading_size.options__7.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.contact-form.settings.heading_size.label"
    },
    {
      "type": "inline_richtext",
      "id": "description",
      "default": "This form is for retailer inquiries only. For all other customer or shopper support requests, please visit the links below this form.",
      "label": "t:sections.contact-form.settings.description.label"
    },
    {
      "type": "color",
      "id": "desc_color",
      "default": "#5c6c75",
      "label": "t:sections.contact-form.settings.desc_color.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
