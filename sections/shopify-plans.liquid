{%- style -%}
  .shopify-plans-section {
    padding: 60px 20px;
    background-color: #f8faff;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #1a1a1a;
  }

  .shopify-plans-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .shopify-plans-header {
    text-align: center;
    margin-bottom: 50px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .shopify-plans-header h2 {
    font-size: 2.5rem;
    color: #001f3f;
    margin-bottom: 20px;
    font-weight: 800;
  }

  .shopify-plans-header p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #4a4a4a;
  }

  .shopify-plans-grid {
    display: grid;
    gap: 30px;
    grid-template-columns: repeat(1, 1fr);
  }

  @media (min-width: 768px) {
    .shopify-plans-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1200px) {
    .shopify-plans-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .plan-card {
    background: #fff;
    border-radius: 20px;
    padding: 40px 25px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    border: 1px solid #eef2f7;
  }

  .plan-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .plan-card.recommended {
    border: 2px solid #7000ff;
    transform: scale(1.05);
    z-index: 1;
  }

  .plan-card.recommended:hover {
    transform: scale(1.05) translateY(-10px);
  }

  .recommended-badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #7000ff, #ff00ff);
    color: #fff;
    padding: 5px 20px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(112, 0, 255, 0.3);
  }

  .plan-name {
    font-size: 1.5rem;
    font-weight: 800;
    color: #001f3f;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .plan-description {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 25px;
    line-height: 1.4;
    min-height: 60px;
  }

  .plan-price-box {
    margin-bottom: 30px;
  }

  .old-price {
    display: block;
    font-size: 1rem;
    color: #999;
    text-decoration: line-through;
    margin-bottom: 5px;
  }

  .current-price {
    font-size: 2.2rem;
    font-weight: 900;
    color: #7000ff;
    display: flex;
    align-items: baseline;
  }

  .iva-text {
    font-size: 0.9rem;
    color: #666;
    margin-left: 5px;
    font-weight: 400;
  }

  .plan-time {
    font-size: 0.9rem;
    font-weight: 600;
    color: #005af0;
    margin-bottom: 25px;
    display: block;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 30px 0;
    flex-grow: 1;
  }

  .feature-item {
    border-bottom: 1px solid #f0f4f8;
    margin-bottom: 0;
  }

  .feature-trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 12px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    text-align: left;
    font-size: 0.95rem;
    font-weight: 600;
    color: #333;
    transition: color 0.2s;
  }

  .feature-trigger:hover {
    color: #005af0;
  }

  .feature-label {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .check-icon {
    width: 18px;
    height: 18px;
    background: #e8f0fe;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #005af0;
    flex-shrink: 0;
  }

  .plus-icon {
    font-size: 1.2rem;
    color: #999;
    transition: transform 0.3s ease;
  }

  .feature-item.active .plus-icon {
    transform: rotate(45deg);
    color: #7000ff;
  }

  .feature-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: #f9fbff;
    padding: 0 15px;
    border-radius: 8px;
  }

  .feature-item.active .feature-content {
    max-height: 200px;
    padding: 10px 15px 15px 15px;
    margin-bottom: 10px;
  }

  .feature-detail-text {
    font-size: 0.85rem;
    line-height: 1.5;
    color: #555;
  }

  .plan-btn {
    display: block;
    width: 100%;
    padding: 15px;
    border-radius: 12px;
    text-align: center;
    text-decoration: none;
    font-weight: 700;
    transition: all 0.3s ease;
    margin-bottom: 15px;
    font-size: 1rem;
  }

  .btn-primary {
    background: #7000ff;
    color: #fff;
    box-shadow: 0 4px 15px rgba(112, 0, 255, 0.2);
  }

  .btn-primary:hover {
    background: #5a00cc;
    box-shadow: 0 6px 20px rgba(112, 0, 255, 0.3);
  }

  .plan-card.recommended .btn-primary {
    background: linear-gradient(135deg, #7000ff, #ff00ff);
  }

  .btn-whatsapp {
    background: #fff;
    color: #25d366;
    border: 2px solid #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .btn-whatsapp:hover {
    background: #25d366;
    color: #fff;
  }

  .whatsapp-icon {
    width: 18px;
    height: 18px;
  }
{%- endstyle -%}

