           "default": "#001E2B"
        },
        {
          "type": "select",
          "id": "h_txt_style",
          "default": "none",
          "options": [
            {
              "value": "none",
              "label": "t:sections.main-404.blocks.heading.settings.h_txt_style.options__1.label"
            },
            {
              "value": "uppercase",
              "label": "t:sections.main-404.blocks.heading.settings.h_txt_style.options__2.label"
            },
            {
