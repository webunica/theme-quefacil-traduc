        { "label": "t:sections.main-404.settings.content_align.options__1.label", "value": "flex-start" },
        { "label": "t:sections.main-404.settings.content_align.options__2.label", "value": "center" },
        { "label": "t:sections.main-404.settings.content_align.options__3.label", "value": "flex-end" }
      ]
    },
    {
      "type": "select",
      "id": "align",
      "label": "t:sections.main-404.settings.align.label",
      "default": "left",
      "options": [
        { "label": "t:sections.main-404.settings.align.options__1.label", "value": "left" },
        { "label": "t:sections.main-404.settings.align.options__2.label", "value": "center" },
        { "label": "t:sections.main-404.settings.align.options__3.label", "value": "right" }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.main-404.settings.header.content"
    },
    {
      "type": "text",
      "id": "section_padding_all_sides",
      "label": "t:sections.main-404.settings.section_padding_all_sides.label",
      "default": "0px 64px 0px 64px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_margin_all_sides",
      "label": "t:sections.main-404.settings.section_margin_all_sides.label",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_padding_mobile_all_sides",
      "label": "t:sections.main-404.settings.section_padding_mobile_all_sides.label",
      "default": "50px 14px 50px 14px",
      "info": "Padding: Top Right Bottom Left"
    },
    {
      "type": "text",
      "id": "section_margin_mobile_all_sides",
      "label": "t:sections.main-404.settings.section_margin_mobile_all_sides.label",
      "default": "0px 0px 0px 0px",
      "info": "Margin: Top Right Bottom Left"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.main-404.blocks.heading.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
