        { "value": "container",
          "label": "t:sections.main-404.settings.layout_style.options__1.label"
        },
        { "value": "container-fluid",
          "label": "t:sections.main-404.settings.layout_style.options__2.label"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "t:sections.main-404.settings.banner_image.label",
      "info": "t:sections.main-404.settings.banner_image.info"
    },
    {
      "type": "url",
      "id": "image_url",
      "label": "t:sections.main-404.settings.image_url.label"
    },
    {
      "type": "text",
