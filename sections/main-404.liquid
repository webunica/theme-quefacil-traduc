            {
              "value": "400",
              "label": "t:sections.main-404.blocks.heading.settings.h_font_weight.options__2.label"
            },
            {
              "value": "500",
              "label": "t:sections.main-404.blocks.heading.settings.h_font_weight.options__3.label"
