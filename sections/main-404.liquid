            },
            {
              "value": "h4",
              "label": "t:sections.main-404.blocks.heading.settings.h_des_size_text.options__4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.main-404.blocks.heading.settings.h_des_size_text.options__5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.main-404.blocks.heading.settings.h_des_size_text.options__6.label"
            }
          ],
          "label": "t:sections.main-404.blocks.heading.settings.h_des_size_text.label"
        },
        {
