      "default":"390"
    },
    {
      "type": "text",
      "id": "image_height",
      "label": "t:sections.main-404.settings.image_height.label",
      "info": "t:sections.main-404.settings.image_height.info",
      "default":"438"
    },
    {
      "type": "select",
