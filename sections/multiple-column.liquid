{% render 'grid-styles' %}
{% render 'section-boundaries', section_id: section.id, section_settings: section.settings %}

<div class="multiple-column {{ section.settings.layout_style }} section-{{ section.id }} position-relative">
  <div
    class="multiple-column-grid grid grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down"
    style="gap: {{ section.settings.space_between }}px;"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign btn_size_text = block.settings.btn_size_text
        assign btn_color = block.settings.btn_color
        assign btn_hover_color = block.settings.btn_hover_color
        assign btn_bg_color = block.settings.btn_bg_color
        assign btn_bg_hover_color = block.settings.btn_bg_hover_color
        assign btn_color = block.settings.btn_color
        assign btn_border = block.settings.btn_border
        assign btn_border_color = block.settings.btn_border_color
        assign btn_border_hover_color = block.settings.btn_border_hover_color
      -%}

      <div
        class="freshcart-grid__item"
        style=" border-radius: {{ section.settings.border_radius }}px; overflow: hidden; position: relative; transition: transform 0.4s ease-in-out"
      >
        <div
          class="freshcart-grid__item--inner multi-column"
          style="
              background-color: {{ section.settings.bg_color }};
              border-radius: {{ section.settings.border_radius }}px;
              background-size: {{ section.settings.background_size }};
              min-height: {{ section.settings.banner_height }}px;
              {% if block.settings.column_image %}
                background-image: url('{{ block.settings.column_image | image_url: width: 424 }}');
              {% else %}
                background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22600%22><rect width=%22100%25%22 height=%22100%25%22 fill=%22%23f0f3f2%22/></svg>');
              {% endif %}
            transition: transform 0.4s ease-in-out;
            padding: {{ section.settings.container_padding }};
            display: flex;
            flex-direction: column;
            align-items: {{ section.settings.content_align }};
            height: 100%;
            justify-content: center;
          "
        >
          <div class="multiple-column-block">
            {% if block.settings.title != blank %}
              <{{ block.settings.heading_font_size }}
                class="multiple-column-name"
                style="
                  color: {{ block.settings.heading_color }};
                  font-weight: {{ block.settings.heading_font_weight }};
                  line-height: {{ block.settings.heading_lineheight }};
                  margin: {{ block.settings.heading_margin }};
                  text-transform: {{ block.settings.heading_txt_style }};
                "
              >
                {{ block.settings.title }}
              </{{ block.settings.heading_font_size }}>
              <style>
                @media (max-width: 767px) {
                  .section#shopify-section-{{ section.id }} .multiple-column-name {
                    font-size: {{ block.settings.heading_mob_size_text }}px;
                  }
                }
              </style>
            {% endif %}

            {% if block.settings.description_text != blank %}
              <p
                class="multiple-column-description"
                style="
                  color: {{ block.settings.des_color }};
                  font-size: {{ block.settings.des_size_text }}px;
                  font-weight: {{ block.settings.des_font_weight }};
                  line-height: {{ block.settings.des_lineheight }};
                  margin: 0;
                "
              >
                {{ block.settings.description_text }}
              </p>
            {% endif %}

            {% if block.settings.button_text != blank %}
              <div class="freshcart-multiple-column {{ block.settings.btn_style }} button__{{ block.id }}">
                <style>
                  .button__{{ block.id }} {
                    width: fit-content;
                  }

                  .button__{{ block.id }} a {
                    font-size: {{ btn_size_text }};
                    cursor: pointer;
                    color: {{ btn_color }};
                    line-height: 1.2;
                    display: block;
                    transition: 0.3s ease-in-out;
                    position: static;
                    width: fit-content;
                  }

                  .button__{{ block.id }} a:before {
                    position: absolute;
                    top: 0;
                    right:0;
                    bottom: 0;
                    left: 0;
                    z-index: 1;
                    content: "";
                    display: block;
                  }

                  {%- if block.settings.btn_style != 'btn-link' -%}
                    .button__{{ block.id }} a {
                      padding: {{ block.settings.btn_padding }};
                      margin: {{ block.settings.btn_margin }};
                      border: {{ btn_border }}px solid {{ btn_border_color }};
                      border-radius: {{ block.settings.btn_border_radius }};
                      text-decoration: none;
                    }
                  {%- endif -%}

                  {%- if block.settings.btn_style == 'btn-fill' -%}
                    .button__{{ block.id }} a {
                      background-color: {{ btn_bg_color }};
                      border: {{ btn_border }}px solid {{ btn_border_color }};
                    }

                    .button__{{ block.id }} a:hover,
                    .button__{{ block.id }} a:focus {
                      background-color: {{ btn_bg_hover_color }};
                      color: {{ btn_hover_color }};
                      border: {{ btn_border }}px solid {{ btn_border_hover_color }};
                    }
                  {%- elsif block.settings.btn_style == 'btn-outline' -%}
                    .button__{{ block.id }} a {
                      background-color: transparent;
                    }

                    .button__{{ block.id }} a:hover,
                    .button__{{ block.id }} a:focus {
                      border: {{ btn_border }}px solid {{ btn_border_hover_color }};
                      color: {{ btn_hover_color }};
                    }
                  {%- elsif block.settings.btn_style == 'btn-link' -%}
                    .button__{{ block.id }} a {
                      text-decoration: underline;
                      background: transparent;
                    }

                    .button__{{ block.id }} a:hover,
                    .button__{{ block.id }} a:focus {
                      color: {{ btn_hover_color }};
                    }
                  {%- endif -%}
                </style>
                <a
                  class="button__link"
                  href="{{ block.settings.button_url }}"
                >
                  {{ block.settings.button_text }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

