<link
  rel="stylesheet"
  href="{{ 'component-card.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'component-price.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'component-slider.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'template-collection.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
<link
  rel="stylesheet"
  href="{{ 'best-sells-collections.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if section.settings.enable_quick_add -%}
  <link
    rel="stylesheet"
    href="{{ 'quick-add.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section#shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
    margin-top: {{ section.settings.section_margin_top | times: 0.7 | round: 0 }}px;
    margin-bottom: {{ section.settings.section_margin_bottom | times: 0.7 | round: 0 }}px;
  }
{%- endstyle -%}

<div class="{{ section.settings.layout_style }}">
  <div class="collection section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %}">
    <div class="collection__title title-wrapper title-wrapper--no-top-margin page-width">
      {%- if section.settings.title != blank -%}
        <h2
          class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="color:{{ section.settings.section_heading_color }}"
        >
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank
        or section.settings.show_description
        and section.settings.collection.description != empty
      -%}
        <div
          class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          style="color:{{ section.settings.desc_color }}"
        >
          {%- if section.settings.show_description -%}
            {{ section.settings.collection.description }}
          {%- else -%}
            {{ section.settings.description -}}
          {%- endif %}
        </div>
      {%- endif -%}
    </div>
    {% assign image_class_2 = 'freshcart-bestseller-image' %}
    {% assign sizes = '100vw' %}
    <div class="banner-width-product">
      <div class="banner position-relative">
        {%- if section.settings.image != blank -%}
          <div class="banner__image media">
            {{
              section.settings.image
              | image_url: width: 3840
              | image_tag: loading: 'lazy', width: 310, height: 390, class: image_class_2, sizes: sizes
            }}
          </div>
        {%- else -%}
          <div class="banner__image media placeholder">
            {{ 'image' | placeholder_svg_tag: 'dark-placeholder-svg' }}
          </div>
        {%- endif -%}

        <div class="banner__image_text">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'heading' -%}
                {% assign headingcolor = block.settings.heading_color %}
                <h2
                  style="color: {{ headingcolor }}"
                  ;
                  class="banner__heading inline-richtext {{ block.settings.heading_size }}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.heading }}
                </h2>
              {%- when 'text' -%}
                {% assign txtcolor = block.settings.text_color %}
                <div
                  style="color: {{ txtcolor }};width:80%;"
                  ;
                  class="banner__text rte {{ block.settings.text_style }}"
                  {{ block.shopify_attributes }}
                >
                  <p>{{ block.settings.text }}</p>
                </div>
              {%- when 'button' -%}
                {% if block.settings.button_text != blank %}
                  <div class="banner__button" style="width: fit-content;">
                    <a class="banner__buttons__link" href="{{ block.settings.button_url }}">
                      {{ block.settings.button_text }}
                    </a>
                    <style>
                        .section#shopify-section-{{ section.id }} .banner-width-product .banner__button a {
                          padding: {{ block.settings.btn_padding }};
                          margin: {{ block.settings.btn_margin }};
                          border: {{ block.settings.btn_border }}px solid  {{ block.settings.btn_bg_color | default: 'rgb(var(--color-primary) )' }};
                          border-radius: {{ block.settings.btn_border_radius }};
                          font-size: {{ block.settings.btn_size_text }};
                          cursor: pointer;
                          color: {{ block.settings.btn_color }};
                          text-decoration: none;
                          line-height: 17px;
                          display: block;
                          background-color:{{ block.settings.btn_bg_color | default: 'rgb(var(--color-primary) )' }};
                          font-weight:700;
                       }

                      .section#shopify-section-{{ section.id }} .banner-width-product .banner__button a:before {
                          position: absolute;
                          top: 0;
                          right:0;
                          bottom: 0;
                          left: 0;
                          z-index: 1;
                          content: "";
                          display: block;
                       }

                      .section#shopify-section-{{ section.id }} .banner-width-product .banner__button a:hover,
                      .section#shopify-section-{{ section.id }} .banner-width-product .banner__button a:focus{
                          background-color:{{ block.settings.btn_bg_hover_color }};
                          color: {{ block.settings.btn_hover_color }};
                          border-color: {{ block.settings.btn_bg_hover_color }};
                      }
                    </style>
                  </div>
                {% endif %}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>

      {% assign collection = collections[section.settings.collection] %}

      {% if collection.products.size > 0 %}
        <div class="freshcart-best-sell-collections" style="width: 100%;">
          <div class="collection-wrapper5">
            {%- paginate collection.products by section.settings.products_to_show -%}
              <!-- Collection Product Grid -->
              <div class="grid product-grid contains-card contains-card--product grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}">
                {%- for product in collection.products -%}
                  <div class="grid__item">
                    {% render 'product-item',
                      card_product: product,
                      media_aspect_ratio: section.settings.image_ratio,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      show_quick_add: section.settings.enable_quick_add,
                      section_id: section.id
                    %}
                  </div>
                {%- endfor -%}
              </div>

              <!-- Pagination -->
              {% render 'pagination', paginate: paginate %}
            {%- endpaginate -%}
          </div>
        </div>
      {% else %}
        <!-- Fallback if no products found in the collection -->
        <div
          class="freshcart-best-sell-collections-placeholder grid product-grid contains-card contains-card--product grid--{{ section.settings.columns_desktop }}-col-desktop{% if section.settings.collection == blank %} grid--2-col-tablet-down{% else %} grid--{{ section.settings.columns_mobile }}-col-tablet-down{% endif %}"
          style="width: 100%;"
        >
          {%- for i in (1..section.settings.products_to_show) -%}
            <div class="grid__item">
              {%- assign placeholder_image = 'collection-' | append: forloop.rindex -%}
              {% render 'card-product',
                show_vendor: section.settings.show_vendor,
                placeholder_image: placeholder_image
              %}
            </div>
          {%- endfor -%}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
    "name": "t:sections.best-sells-collection.name",
    "tag": "section",
    "class": "section section-bestsells-collection",
    "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
    },
    "settings": [
        {
            "type": "select",
            "id": "layout_style",
            "label": "t:sections.best-sells-collection.settings.layout_style.label",
            "default": "container",
            "options": [
                {
                    "value": "container",
                    "label": "t:sections.best-sells-collection.settings.layout_style.options__1.label"
                },
                {
                    "value": "container-fluid",
                    "label": "t:sections.best-sells-collection.settings.layout_style.options__2.label"
                }
            ]
        },
        {
            "type": "inline_richtext",
            "id": "title",
            "default": "Featured collection",
            "label": "t:sections.best-sells-collection.settings.title.label"
        },
        {
            "type": "select",
            "id": "heading_size",
            "options": [
                {
                    "value": "h0",
                    "label": "t:sections.best-sells-collection.settings.heading_size.options__1.label"
                },
                {
                    "value": "h1",
                    "label": "t:sections.best-sells-collection.settings.heading_size.options__2.label"
                },
                {
                    "value": "h2",
                    "label": "t:sections.best-sells-collection.settings.heading_size.options__3.label"
                },
                {
                    "value": "h3",
                    "label": "t:sections.best-sells-collection.settings.heading_size.options__4.label"
                },
                {
                    "value": "h4",
                    "label": "t:sections.best-sells-collection.settings.heading_size.options__5.label"
                }
            ],
            "default": "h3",
            "label": "t:sections.all.heading_size.label"
        },
        {
            "type": "color",
            "id": "section_heading_color",
            "label": "t:sections.best-sells-collection.settings.section_heading_color.label",
            "default": "#001e2b"
        },
        {
            "type": "richtext",
            "id": "description",
            "label": "t:sections.best-sells-collection.settings.description.label"
        },
        {
            "type": "checkbox",
            "id": "show_description",
            "label": "t:sections.best-sells-collection.settings.show_description.label",
            "default": false
        },
        {
            "type": "select",
            "id": "description_style",
            "label": "t:sections.best-sells-collection.settings.description_style.label",
            "options": [
                {
                    "value": "body",
                    "label": "t:sections.best-sells-collection.settings.description_style.options__1.label"
                },
                {
                    "value": "subtitle",
                    "label": "t:sections.best-sells-collection.settings.description_style.options__2.label"
                },
                {
                    "value": "uppercase",
                    "label": "t:sections.best-sells-collection.settings.description_style.options__3.label"
                }
            ],
            "default": "body"
        },
        {
            "type": "color",
            "id": "desc_color",
            "label": "t:sections.best-sells-collection.settings.desc_color.label",
            "default": "#5c6c75"
        },
        {
            "type": "header",
            "content": "t:sections.best-sells-collection.settings.banner.content"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:sections.best-sells-collection.settings.image.label"
        },
        {
            "type": "header",
            "content": "t:sections.best-sells-collection.settings.product.content"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "t:sections.best-sells-collection.settings.collection.label"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "min": 1,
            "max": 6,
            "step": 1,
            "default": 3,
            "label": "t:sections.best-sells-collection.settings.products_to_show.label"
        },
        {
            "type": "range",
            "id": "columns_desktop",
            "min": 1,
            "max": 6,
            "step": 1,
            "default": 3,
            "label": "t:sections.best-sells-collection.settings.columns_desktop.label"
        },
        {
            "type": "header",
            "content": "t:sections.best-sells-collection.settings.header.content"
        },
        {
            "type": "select",
            "id": "image_ratio",
            "options": [
                {
                    "value": "adapt",
                    "label": "t:sections.best-sells-collection.settings.image_ratio.options__1.label"
                },
                {
                    "value": "portrait",
                    "label": "t:sections.best-sells-collection.settings.image_ratio.options__2.label"
                },
                {
                    "value": "square",
                    "label": "t:sections.best-sells-collection.settings.image_ratio.options__3.label"
                }
            ],
            "default": "adapt",
            "label": "t:sections.best-sells-collection.settings.image_ratio.label"
        },
        {
            "type": "checkbox",
            "id": "show_secondary_image",
            "default": false,
            "label": "t:sections.best-sells-collection.settings.show_secondary_image.label"
        },
        {
            "type": "checkbox",
            "id": "show_vendor",
            "default": false,
            "label": "t:sections.best-sells-collection.settings.show_vendor.label"
        },
        {
            "type": "checkbox",
            "id": "show_rating",
            "default": false,
            "label": "t:sections.best-sells-collection.settings.show_rating.label",
            "info": "t:sections.best-sells-collection.settings.show_rating.info"
        },
        {
            "type": "checkbox",
            "id": "enable_quick_add",
            "default": false,
            "label": "t:sections.best-sells-collection.settings.enable_quick_buy.label"
        },
        {
            "type": "header",
            "content": "t:sections.best-sells-collection.settings.header_mobile.content"
        },
        {
            "type": "select",
            "id": "columns_mobile",
            "default": "2",
            "label": "t:sections.best-sells-collection.settings.columns_mobile.label",
            "options": [
                {
                    "value": "1",
                    "label": "t:sections.best-sells-collection.settings.columns_mobile.options__1.label"
                },
                {
                    "value": "2",
                    "label": "t:sections.best-sells-collection.settings.columns_mobile.options__2.label"
                }
            ]
        },
        {
            "type": "header",
            "content": "t:sections.all.padding.section_padding_heading"
        },
        {
            "type": "range",
            "id": "section_padding_top",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.best-sells-collection.settings.section_padding_top.label",
            "default": 0
        },
        {
            "type": "range",
            "id": "section_padding_bottom",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.best-sells-collection.settings.section_padding_bottom.label",
            "default": 0
        },
        {
            "type": "range",
            "id": "section_margin_top",
            "min": 0,
            "max": 160,
            "step": 4,
            "unit": "px",
            "label": "t:sections.best-sells-collection.settings.section_margin_top.label",
            "default": 112
        },
        {
            "type": "range",
            "id": "section_margin_bottom",
            "min": 0,
            "max": 100,
            "step": 4,
            "unit": "px",
            "label": "t:sections.best-sells-collection.settings.section_margin_bottom.label",
            "default": 0
        }
    ],
    "blocks": [
        {
            "type": "heading",
            "name": "t:sections.best-sells-collection.blocks.heading.name",
            "limit": 1,
            "settings": [
                {
                    "type": "inline_richtext",
                    "id": "heading",
                    "default": "Image banner",
                    "label": "t:sections.best-sells-collection.blocks.heading.settings.heading.label"
                },
                {
                    "type": "color",
                    "id": "heading_color",
                    "label": "Heading color",
                    "default": "#ffffff"
                },
                {
                    "type": "select",
                    "id": "heading_size",
                    "options": [
                        {
                            "value": "h2",
                            "label": "t:sections.all.heading_size.options__1.label"
                        },
                        {
                            "value": "h1",
                            "label": "t:sections.all.heading_size.options__2.label"
                        },
                        {
                            "value": "h0",
                            "label": "t:sections.all.heading_size.options__3.label"
                        }
                    ],
                    "default": "h1",
                    "label": "t:sections.all.heading_size.label"
                }
            ]
        },
        {
            "type": "text",
            "name": "t:sections.best-sells-collection.blocks.text.name",
            "limit": 1,
            "settings": [
                {
                    "type": "inline_richtext",
                    "id": "text",
                    "default": "Give customers details about the banner image(s) or content on the template.",
                    "label": "t:sections.best-sells-collection.blocks.text.settings.text.label"
                },
                {
                    "type": "color",
                    "id": "text_color",
                    "label": "Text color",
                    "default": "#ffffff"
                },
                {
                    "type": "select",
                    "id": "text_style",
                    "options": [
                        {
                            "value": "body",
                            "label": "t:sections.best-sells-collection.blocks.text.settings.text_style.options__1.label"
                        },
                        {
                            "value": "subtitle",
                            "label": "t:sections.best-sells-collection.blocks.text.settings.text_style.options__2.label"
                        },
                        {
                            "value": "caption-with-letter-spacing",
                            "label": "t:sections.best-sells-collection.blocks.text.settings.text_style.options__3.label"
                        }
                    ],
                    "default": "body",
                    "label": "t:sections.best-sells-collection.blocks.text.settings.text_style.label"
                }
            ]
        },
        {
            "type": "button",
            "name": "t:sections.best-sells-collection.blocks.button.name",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id": "button_text",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.button_text.label",
                    "default": "Shop Now"
                },
                {
                    "type": "url",
                    "id": "button_url",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.button_url.label"
                },
                {
                    "type": "color",
                    "id": "btn_color",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_color.label",
                    "default": "#fff"
                },
                {
                    "type": "color",
                    "id": "btn_hover_color",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_hover_color.label",
                    "default": "#fff"
                },
                {
                    "type": "color",
                    "id": "btn_bg_color",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_bg_color.label"
                },
                {
                    "type": "color",
                    "id": "btn_bg_hover_color",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_bg_hover_color.label"
                },
                {
                    "type": "text",
                    "id": "btn_padding",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_padding.label",
                    "default": "10px 17px 10px 17px",
                    "info": "Padding: Top Right Bottom Left"
                },
                {
                    "type": "text",
                    "id": "btn_margin",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_margin.label",
                    "default": "0px 0px 0px 0px",
                    "info": "Margin: Top Right Bottom Left"
                },
                {
                    "type": "range",
                    "id": "btn_border",
                    "min": 1,
                    "max": 10,
                    "step": 1,
                    "unit": "px",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_border.label",
                    "default": 1
                },
                {
                    "type": "text",
                    "id": "btn_border_radius",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_border_radius.label",
                    "default": "6px"
                },
                {
                    "type": "text",
                    "id": "btn_size_text",
                    "default": "14px",
                    "label": "t:sections.best-sells-collection.blocks.button.settings.btn_size_text.label"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.best-sells-collection.presets.name",
            "blocks": [
                {
                    "type": "heading"
                },
                {
                    "type": "text"
                },
                {
                    "type": "button"
                }
            ]
        }
    ]
}
{% endschema %}
