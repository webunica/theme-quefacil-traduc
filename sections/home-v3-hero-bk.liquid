<link
  rel="stylesheet"
  href="{{ 'home-v3-hero.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .home-v3-hero-{{ section.id }} {
    margin: {{ section.settings.section_margin_all_sides }};
    padding: {{ section.settings.section_padding_all_sides }};
  }

  .home-v3-hero-{{ section.id }} .section-2-column-banner__columns {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: {{ section.settings.columns_gap }}px;
    align-items: stretch;
  }

  .home-v3-hero-{{ section.id }} .section-2-column-banner__column {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.banner_radius }}px;
  }

  .home-v3-hero-{{ section.id }} .first-column {
    min-height: {{ section.settings.img_height }}px;
    background: #f4f4f4;
  }

  .home-v3-hero-{{ section.id }} .section-2-column-banner__column-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-v3-hero-{{ section.id }} .section-2-column-banner__column-content {
    position: relative;
    z-index: 3;
    padding: {{ section.settings.content_padding }};
    max-width: {{ section.settings.content_max_width }}px;
  }

  .home-v3-hero-{{ section.id }} .first-column::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      90deg,
      rgba(255,255,255,.94) 0%,
      rgba(255,255,255,.72) 45%,
      rgba(255,255,255,.18) 100%
    );
    pointer-events: none;
  }

  .home-v3-hero-{{ section.id }} .first-column .section-2-column-banner__column-content {
    position: relative;
    z-index: 2;
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button {
    width: fit-content;
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button a {
    font-size: {{ section.settings.btn_size_text }};
    cursor: pointer;
    color: {{ section.settings.btn_color }};
    line-height: 1.2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: 0.25s ease-in-out;
    width: fit-content;
    padding: {{ section.settings.btn_padding }};
    margin: {{ section.settings.btn_margin }};
    border: {{ section.settings.btn_border }}px solid {{ section.settings.btn_border_color }};
    border-radius: {{ section.settings.btn_border_radius }};
    text-decoration: none;
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button.btn-fill a {
    background-color: {{ section.settings.btn_bg_color }};
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button.btn-outline a {
    background-color: transparent;
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button.btn-link a {
    background: transparent;
    border-color: transparent;
    padding-left: 0;
    padding-right: 0;
    text-decoration: underline;
  }

  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button a:hover,
  .home-v3-hero-{{ section.id }} .freshcart-home-v3-column-1-button a:focus {
    background-color: {{ section.settings.btn_bg_hover_color }};
    color: {{ section.settings.btn_hover_color }};
    border-color: {{ section.settings.btn_border_hover_color }};
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards {
    --slider-speed: {{ section.settings.slider_speed }}s;
    --slider-card-width: {{ section.settings.slider_card_width }}px;
    --slider-gap: {{ section.settings.slider_gap }}px;

    min-width: 0;
    overflow: hidden;
    border-radius: {{ section.settings.banner_radius }}px;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__track {
    display: flex;
    align-items: stretch;
    gap: var(--slider-gap);
    width: max-content;
    min-height: 100%;
    animation: homeV3RunningCards{{ section.id }} var(--slider-speed) linear infinite;
    will-change: transform;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards:hover .home-v3-running-cards__track {
    animation-play-state: paused;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__card {
    position: relative;
    flex: 0 0 var(--slider-card-width);
    min-height: {{ section.settings.slider_card_height }}px;
    overflow: hidden;
    border-radius: {{ section.settings.card_radius }}px;
    background: #f4f4f4;
    box-shadow: 0 10px 30px rgba(0,0,0,.08);
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .45s ease;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__card:hover .home-v3-running-cards__image {
    transform: scale(1.05);
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      90deg,
      rgba(255,255,255,.94) 0%,
      rgba(255,255,255,.76) 48%,
      rgba(255,255,255,.18) 100%
    );
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__content {
    position: relative;
    z-index: 3;
    padding: {{ section.settings.card_content_padding }};
    max-width: {{ section.settings.card_content_width }}%;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__pretitle {
    margin: 0 0 8px;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__title {
    letter-spacing: -0.03rem;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__description {
    font-size: 15px;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__button {
    position: relative;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    text-decoration: none;
    line-height: 1.2;
    transition: all .25s ease;
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__button:hover {
    opacity: .85;
    transform: translateY(-1px);
  }

  .home-v3-hero-{{ section.id }} .home-v3-running-cards__link-fill {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  @keyframes homeV3RunningCards{{ section.id }} {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 989px) {
    .home-v3-hero-{{ section.id }} .section-2-column-banner__columns {
      grid-template-columns: 1fr;
    }

    .home-v3-hero-{{ section.id }} .first-column {
      min-height: {{ section.settings.img_height_mobile }}px;
    }

    .home-v3-hero-{{ section.id }} .home-v3-running-cards {
      --slider-card-width: {{ section.settings.slider_card_width_mobile }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .home-v3-hero-{{ section.id }} {
      margin: {{ section.settings.section_margin_mobile }};
      padding: {{ section.settings.section_padding_mobile }};
    }

    .home-v3-hero-{{ section.id }} .section-2-column-banner__columns {
      gap: {{ section.settings.columns_gap_mobile }}px;
    }

    .home-v3-hero-{{ section.id }} .section-2-column-banner__column-content {
      padding: {{ section.settings.content_padding_mobile }};
      max-width: 92%;
    }

    .home-v3-hero-{{ section.id }} .home-v3-running-cards {
      --slider-card-width: {{ section.settings.slider_card_width_mobile }}px;
    }

    .home-v3-hero-{{ section.id }} .home-v3-running-cards__card {
      min-height: {{ section.settings.slider_card_height_mobile }}px;
    }

    .home-v3-hero-{{ section.id }} .home-v3-running-cards__content {
      padding: {{ section.settings.card_content_padding_mobile }};
      max-width: {{ section.settings.card_content_width_mobile }}%;
    }
  }
{%- endstyle -%}

<div class="home-v3-hero home-v3-hero-{{ section.id }} {{ section.settings.layout_style }}">
  <div class="page-width">
    <div class="section-2-column-banner__columns hero-column {{ section.type }}">

      <div class="section-2-column-banner__column first-column stretched-link">
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: section.settings.img_width }}"
            width="{{ section.settings.img_width }}"
            height="{{ section.settings.img_height }}"
            alt="{{ section.settings.image_alt | escape }}"
            class="section-2-column-banner__column-image"
            loading="lazy"
          >
        {% else %}
          <div class="section-2-column-banner__column-image">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}

        <div class="section-2-column-banner__column-content">
          {% if section.settings.pretitle != blank %}
            <{{ section.settings.pretitle_font_size }}
              class="pretitle"
              style="
                color: {{ section.settings.pretitle_color }};
                font-weight: {{ section.settings.pretitle_font_weight }};
                line-height: {{ section.settings.pretitle_lineheight }};
                text-transform: {{ section.settings.pretitle_txt_style }};
              "
            >
              {{ section.settings.pretitle }}
            </{{ section.settings.pretitle_font_size }}>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h1
              class="section-heading {{ section.settings.heading_font_size }}"
              style="
                color: {{ section.settings.heading_color }};
                font-weight: {{ section.settings.heading_font_weight }};
                line-height: {{ section.settings.heading_lineheight }};
                margin: {{ section.settings.heading_margin }};
                text-transform: {{ section.settings.heading_txt_style }};
                letter-spacing: -.03rem;
              "
            >
              {{ section.settings.heading }}
            </h1>
          {% endif %}

          {% if section.settings.posttitle != blank %}
            <{{ section.settings.posttitle_font_size }}
              style="
                color: {{ section.settings.posttitle_color }};
                font-weight: {{ section.settings.posttitle_font_weight }};
                line-height: {{ section.settings.posttitle_lineheight }};
                margin: {{ section.settings.posttitle_margin }};
                text-transform: {{ section.settings.posttitle_txt_style }};
              "
            >
              {{ section.settings.posttitle }}
            </{{ section.settings.posttitle_font_size }}>
          {% endif %}

          {% if section.settings.description != blank %}
            <{{ section.settings.desc_font_size }}
              style="
                color: {{ section.settings.desc_color }};
                font-weight: {{ section.settings.desc_font_weight }};
                line-height: {{ section.settings.desc_lineheight }};
                margin: {{ section.settings.desc_margin }};
                text-transform: {{ section.settings.desc_txt_style }};
              "
            >
              {{ section.settings.description }}
            </{{ section.settings.desc_font_size }}>
          {% endif %}

          {% if section.settings.button_text != blank %}
            <div class="freshcart-home-v3-column-1-button {{ section.settings.btn_style }} button">
              <a
                class="button__link"
                href="{{ section.settings.button_url }}"
              >
                {{ section.settings.button_text }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="section-2-column-banner__column second-column home-v3-running-cards">
        <div class="home-v3-running-cards__viewport">
          <div class="home-v3-running-cards__track">

            {% for repeat in (1..2) %}
              {% for block in section.blocks %}
                {% if block.type == 'banner' %}
                  <article
                    class="home-v3-running-cards__card"
                    {% if repeat == 1 %}{{ block.shopify_attributes }}{% endif %}
                    {% if repeat == 2 %}aria-hidden="true"{% endif %}
                  >
                    {% if block.settings.button_url != blank %}
                      <a
                        class="home-v3-running-cards__link-fill"
                        href="{{ block.settings.button_url }}"
                        aria-label="{{ block.settings.heading | default: block.settings.button_text | escape }}"
                      ></a>
                    {% endif %}

                    {% if block.settings.image %}
                      <img
                        src="{{ block.settings.image | image_url: width: block.settings.img_width }}"
                        alt="{{ block.settings.image_alt | escape }}"
                        class="home-v3-running-cards__image"
                        width="{{ block.settings.img_width }}"
                        height="{{ block.settings.img_height }}"
                        loading="lazy"
                      >
                    {% else %}
                      <div class="home-v3-running-cards__placeholder">
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {% endif %}

                    <div class="home-v3-running-cards__overlay"></div>

                    <div class="home-v3-running-cards__content">
                      {% if block.settings.pretitle != blank %}
                        <div
                          class="home-v3-running-cards__pretitle"
                          style="
                            color: {{ block.settings.pretitle_color }};
                            font-weight: {{ block.settings.pretitle_font_weight }};
                            line-height: {{ block.settings.pretitle_lineheight }};
                            text-transform: {{ block.settings.pretitle_txt_style }};
                          "
                        >
                          {{ block.settings.pretitle }}
                        </div>
                      {% endif %}

                      {% if block.settings.heading != blank %}
                        <h3
                          class="home-v3-running-cards__title {{ block.settings.heading_font_size }}"
                          style="
                            color: {{ block.settings.heading_color }};
                            font-weight: {{ block.settings.heading_font_weight }};
                            line-height: {{ block.settings.heading_lineheight }};
                            margin: {{ block.settings.heading_margin }};
                            text-transform: {{ block.settings.heading_txt_style }};
                          "
                        >
                          {{ block.settings.heading | newline_to_br }}
                        </h3>
                      {% endif %}

                      {% if block.settings.posttitle != blank %}
                        <div
                          class="home-v3-running-cards__posttitle"
                          style="
                            color: {{ block.settings.posttitle_color }};
                            font-weight: {{ block.settings.posttitle_font_weight }};
                            line-height: {{ block.settings.posttitle_lineheight }};
                            margin: {{ block.settings.posttitle_margin }};
                            text-transform: {{ block.settings.posttitle_txt_style }};
                          "
                        >
                          {{ block.settings.posttitle }}
                        </div>
                      {% endif %}

                      {% if block.settings.description != blank %}
                        <div
                          class="home-v3-running-cards__description"
                          style="
                            color: {{ block.settings.desc_color }};
                            font-weight: {{ block.settings.desc_font_weight }};
                            line-height: {{ block.settings.desc_lineheight }};
                            margin: {{ block.settings.desc_margin }};
                            text-transform: {{ block.settings.desc_txt_style }};
                          "
                        >
                          {{ block.settings.description }}
                        </div>
                      {% endif %}

                      {% if block.settings.button_text != blank %}
                        <a
                          class="home-v3-running-cards__button"
                          href="{{ block.settings.button_url }}"
                          style="
                            color: {{ block.settings.btn_color }};
                            background-color: {{ block.settings.btn_bg_color }};
                            border: {{ block.settings.btn_border }}px solid {{ block.settings.btn_border_color }};
                            border-radius: {{ block.settings.btn_border_radius }};
                            padding: {{ block.settings.btn_padding }};
                            margin: {{ block.settings.btn_margin }};
                            font-size: {{ block.settings.btn_size_text }};
                          "
                        >
                          {{ block.settings.button_text }}
                        </a>
                      {% endif %}
                    </div>
                  </article>
                {% endif %}
              {% endfor %}
            {% endfor %}

          </div>
        </div>
      </div>

    </div>
  </div>
</div>

